@using Newtonsoft.Json

@model ShampanPOS.Models.CollectionVM
@{
    ViewBag.Title = "Collection Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var serial = 1;
}


<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"> Collection Data Entry </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li id="btnBack"><img src="~/Content/css/ButtonsIcons/back-icon.png" title="Click for Go Back" /></li>
                </ol>
            </div>
        </div>
    </div>
</div>



<div class="card">
    <div class="card-header p-2">

        @if (Model.IsActive)
        {
            <button type="button" class="button sslPush">Already Posted</button>

            <button style="float:right;" type="button" title="Add New" data-url="/DMS/Collection/Create" onclick="GoTo(this)" class="button NewButton addNewButton">
                New
            </button>
        }
        else if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
        {
            <button type="button" class="button btnsave sslUpdate">Update</button>

            <button type="button" class="button btnPost sslPost">Post</button>

            <button type="button" style="display:none;" class="button sslPush">Already Posted</button>

            <button style="float:right;" type="button" title="Add New" data-url="/DMS/Collection/Create" onclick="GoTo(this)" class="button NewButton addNewButton">
                New
            </button>
        }
        else
        {
            <div style="display:none;" class="divUpdate">
                <button type="button" class="button btnsave sslUpdate">Update</button>
                <button type="button" class="button btnPost sslPost">Post</button>
                <button type="button" style="display:none;" class="button sslPush">Already Posted</button>

                <button style="float:right;" type="button" title="Add New" data-url="/DMS/Collection/Create" onclick="GoTo(this)" class="button NewButton addNewButton">
                    New
                </button>

            </div>
            <div class="divSave">
                <button class="button btnsave sslSave" type="button" id="">Save</button>
            </div>
        }

    </div>
</div>

<div class="container-fluid">
    <form id="frmEntry">
        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title"> Collection Info </h3>
            </div>
            <div class="card-body">

                @Html.HiddenFor(model => model.Id)
                @Html.HiddenFor(model => model.Operation)
                @Html.Hidden("detailsListJson", JsonConvert.SerializeObject(Model.collectionDetailList ?? new List<ShampanPOS.Models.CollectionDetailVM>()))

                <div class="form-group row">

                    <div class="col-sm-2 codeWidth">
                        @Html.LabelFor(model => model.Code)
                        <div style="display: flex; align-items: center;">
                            <span id="btnPrevious" class="fa fa-backward" style="color: darkseagreen;"></span>&nbsp;
                            @Html.TextBoxFor(model => model.Code, new { placeholder = "Code Auto Generate", @class = " csCode  form-control form-control-sm", @readonly = "readonly", @style = "width:140px;" }) &nbsp;
                            <span id="btnNext" class="fa fa-forward" style="color: darkseagreen;"></span>
                        </div>
                    </div>

                    @*<div class="col-sm-2">
            @Html.LabelFor(model => model.TransactionDate)
            <div class="input-group date">
                @Html.TextBoxFor(model => model.TransactionDate, new { @class = " required form-control form-control-sm dateRange" })
                <div class="input-group-append">
                    <div class="input-group-text"><i class="far fa-calendar-alt"></i></div>
                </div>
            </div>
        </div>*@
                    <div class="col-sm-2 pr-3">
                        @Html.LabelFor(model => model.TransactionDate)

                        @Html.TextBoxFor(model => model.TransactionDate, new
                   {
                       @class = "kendoTransactionDate",
                       style = "width:100%; height:2em;"
                   })
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.CustomerId)
                        <div class="input-group">
                            @Html.TextBoxFor(model => model.CustomerId, new { @class = "required form-control form-control-sm" })
                        </div>
                        <span id="titleError1" class="text-danger" style="display:none;"></span>
                    </div>



                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.ChequeNo)
                        <div class="input-group">
                            @Html.TextBoxFor(model => model.ChequeNo, new { placeholder = "Enter Cheque No", @class = "form-control form-control-sm", type = "number", @oninput = "this.value = this.value.replace(/[^0-9]/g, '')" })
                        </div>
                        @Html.ValidationMessageFor(model => model.ChequeNo, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.ChequeBankName)
                        <div class="input-group">
                            @Html.TextBoxFor(model => model.ChequeBankName, new { placeholder = " Enter Bank Name", @class = "form-control form-control-sm" })
                        </div>
                    </div>

                    @*<div class="col-sm-2">
            @Html.LabelFor(model => model.ChequeDate)
            <div class="input-group date">
                @Html.TextBoxFor(model => model.ChequeDate, new { @class = "  form-control form-control-sm dateRange" })
                <div class="input-group-append">
                    <div class="input-group-text"><i class="far fa-calendar-alt"></i></div>
                </div>
            </div>
        </div>*@

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.ChequeDate)

                        @Html.TextBoxFor(model => model.ChequeDate, new
                   {
                       @class = "kendoChequeDate",
                       style = "width:100%; height:2em;"

                   })
                    </div>

                </div>

                <div class="form-group row">

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.BankAccountId)
                        <div class="input-group">
                            @Html.TextBoxFor(model => model.BankAccountId, new { @class = " form-control form-control-sm" })
                        </div>
                        <span id="titleError1" class="text-danger" style="display:none;"></span>
                    </div>

                    <div class="col-sm-2" style="flex-direction: column">
                        @Html.LabelFor(model => model.IsCash)
                        <div class="Onoffbtn">
                            <div class="input-group" style="margin-bottom: -26px; width: 78%;">
                                <input id="IsCash"
                                       value="true"
                                       type="checkbox"
                                       name="my-checkbox"
                                       checked
                                       data-bootstrap-switch
                                       data-off-color="danger"
                                       data-on-color="success"
                                       data-on-text="Bank"
                                       data-off-text="Cash">
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.Comments)
                        <div class="input-group">
                            @Html.TextAreaFor(model => model.Comments, new { placeholder = "Enter Comment", @class = "form-control form-control-sm" })
                        </div>
                    </div>

                </div>


            </div>

            <div class="card card-secondary">
                <div class="card-header">
                    <h3 class="card-title"> Details </h3>
                </div>
                <div class="card-body">

                    @*<button id="addRows" class="k-button k-primary">
                            <span class="k-icon k-i-plus"></span> Add
                        </button>*@

                    <div style="overflow-x: auto; white-space: nowrap;">

                        <div id="CollectionDetailsGrid"></div>

                    </div>

                </div>
            </div>




            <div class="card">
                <div class="card-header p-2">
                    <div class="card-body">
                        <div class="form-group row">



                            <div class="col-sm-2">
                                @Html.LabelFor(model => model.TotalCollectAmount)
                                <div class="input-group">
                                    @Html.TextBoxFor(
                                        model => model.TotalCollectAmount,
                                        new
                                        {
                                            @placeholder = "Total Collect Amount",
                                            @class = "form-control form-control-sm text-right NumberCheck priceLen",
                                            @readonly = "readonly",
                                            id = "TotalCollectAmount"
                                        }
                                    )
                                </div>
                            </div>



                        </div>
                    </div>
                </div>
            </div>


        </div>
    </form>

    <div class="card" style="flex-direction: row; justify-content: space-between; align-items: center;">
        <div class="card-header p-2">

            @if (Model.IsActive)
            {
                <button type="button" class="button sslPush">Already Posted</button>
            }
            else if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
            {
                <div style="display: flex; align-items: center; gap: 5px;">
                    <button type="button" class="button btnsave sslUpdate">Update</button>

                    <button type="button" class="button btnPost sslPost">Post</button>
                    @*<button class="button sslPrintC " data-id="@Model.Id" style="float:right;">Print</button>*@

                    <button type="button" style="display:none;" class="button sslPush">Already Posted</button>
                </div>
            }
            else
            {
                <div style="display:none;" class="divUpdate">
                    <button type="button" class="button btnsave sslUpdate">Update</button>
                    <button type="button" class="button btnPost sslPost">Post</button>
                    <button type="button" style="display:none;" class="button sslPush">Already Posted</button>
                </div>
                <div class="divSave">
                    <button class="button btnsave sslSave" type="button" id="">Save</button>
                </div>
            }

        </div>
        <div class="auditshow"> <img src="~/Content/Images/audit.png" title="Click for Audit" /> </div>
    </div>

    <div class="card card-secondary auditcard">

        <div class="card-header">
            <h3 class="card-title">Audit Details</h3>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-sm-2">
                    <div class="row">
                        @Html.Label("Type")
                    </div>
                </div>
                <div class="col-sm-10">
                    <div class="row">
                        <div class="col-sm-3">
                            @Html.Label("Created")
                        </div>
                        <div class="col-sm-3">
                            @Html.Label("Updated")
                        </div>
                        @*<div class="col-sm-3">
                            @Html.Label("Posted")
                        </div>*@
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-sm-2">
                    <div class="row">
                        <div class="col-sm-12">
                            @Html.Label("By")<br /><div class="clearfix">&nbsp;</div>
                            @Html.Label("On")<br /><div class="clearfix">&nbsp;</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-10">
                    <div class="row">
                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.CreatedBy, new { @class = "CreatedBy  form-control form-control-sm ", @readonly = "readonly" })
                            <div class="clearfix">&nbsp;</div>
                            @Html.TextBoxFor(model => model.CreatedOn, new { @class = "CreatedOn  form-control form-control-sm ", @readonly = "readonly" })
                        </div>

                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.LastModifiedBy, new { @class = "LastUpdateBy  form-control form-control-sm lub", @readonly = "readonly" })
                            <div class="clearfix">&nbsp;</div>
                            @Html.TextBoxFor(model => model.LastModifiedOn, new { @class = "LastUpdateOn  form-control form-control-sm luo", @readonly = "readonly" })
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

<div id="poWindow" style="display:none;">
    <div id="windowGrid"></div>
</div>

@section scripts{
    <script src="~/Areas/Common/js/Services/CommonService.js"></script>
    <script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>
    <script src="~/Areas/DMS/js/Controllers/CollectionController.js"></script>
    <script src="~/Areas/Common/js/Services/CommonValidationHelper.js"></script>


    <script>
        $(document).ready(function () {

            $("#tabs").tabs();

            $("#IsActive").bootstrapSwitch();
            $("#IsCash").bootstrapSwitch();

            CollectionController.init();
        });
    </script>


}

