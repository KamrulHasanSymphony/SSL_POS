                select: applyPurchaseOrderSupplierFilter
            });
        }

        function applyPurchaseOrderSupplierFilter() {

            var combo = $("#PurchaseOrderSupplierId").data("kendoComboBox");
            var supplierId = combo ? combo.value() : "";

            var grid = $("#purchaseOrderGrid").data("kendoGrid");

            if (!grid) return;

            if (!supplierId) {
                grid.dataSource.filter([]);
                return;
            }

            grid.dataSource.filter({
                field: "SupplierId",
                operator: "eq",
                value: parseInt(supplierId)
            });
        }
        function ClearPurchase() {
            $("#PurchaseId").val("");
            $("#PurchaseCode").val("");
        }

        function ClearPurchaseOrder() {
            $("#PurchaseOrderId").val("");
            $("#PurchaseOrderCode").val("");
        }

    function GetSupplierComboBox() {

        $("#SupplierId").kendoMultiColumnComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            height: 400,
            columns: [
                { field: "Code", title: "Code", width: 100 },
                { field: "Name", title: "Name", width: 150 }
            ],
            filter: "contains",
            filterFields: ["Code", "Name"],
            dataSource: {
                transport: {
                    read: "/Common/Common/GetSupplierList"
                }
            },
            placeholder: "Select Supplier",

            dataBound: function () {
                if (getSupplierId) {
                    this.value(parseInt(getSupplierId));
                }
            }
        });
    }



    function PrintPurchaseReport() {
        debugger;
    var supplierCombo = $("#SupplierId").data("kendoMultiColumnComboBox");

    var supplierId = supplierCombo ? supplierCombo.value() : 0;
    var supplierName = supplierCombo ? supplierCombo.text() : "";

    var productId = $("#ProductId").val() || 0;
    var productName = $("#ProductName").val() || "";

    var purchaseId = $("#PurchaseId").val() || 0;
    var purchaseOrderId = $("#PurchaseOrderId").val() || 0;

    var isSummary = $("#IsSummary").is(":checked");

    supplierId = supplierId || 0;
    productId = productId || 0;

    // =========================================
    // Purchase Date
    // =========================================

    var purchaseFromDate = "";
    var purchaseToDate = "";

    if ($("#chkPurchaseFromDate").is(":checked")) {
        purchaseFromDate = $("#PurchaseFromDate").val();

    }

    if ($("#chkPurchaseToDate").is(":checked")) {
        purchaseToDate = $("#PurchaseToDate").val();
    }

    // =========================================
    // Invoice Date
    // =========================================

    var fromDate = "";
    var toDate = "";

    if ($("#chkInvoiceFromDate").is(":checked")) {
        fromDate = $("#InvoiceFromDate").val();
    }

    if ($("#chkInvoiceToDate").is(":checked")) {
        toDate = $("#InvoiceToDate").val();
    }

    // =========================================
    // URL
        // =========================================

var url = '@Url.Action("PurchaseOrdervsPurchaseReportList", "Purchase", new { area = "DMS" })'
    + '?supplierId=' + supplierId
    + '&supplierName=' + encodeURIComponent(supplierName)

    + '&productId=' + productId
    + '&productName=' + encodeURIComponent(productName)

    + '&purchaseId=' + purchaseId
    + '&purchaseOrderId=' + purchaseOrderId

    + '&purchaseFromDate=' + purchaseFromDate
    + '&purchaseToDate=' + purchaseToDate

    + '&fromDate=' + fromDate
    + '&toDate=' + toDate

    + '&isSummary=' + isSummary;

    window.open(url, "_blank");
}

