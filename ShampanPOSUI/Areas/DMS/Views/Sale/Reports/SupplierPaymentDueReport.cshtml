@model List<ShampanPOS.Models.SupplierPaymentDueVM>
@{
    ViewBag.Title = "Supplier Payment Due";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var grandTotalPurchase = Model.Sum(x => x.PurchaseAmount);
    var grandTotalPayment = Model.Sum(x => x.TotalPaymentAmount);
    var grandTotalDue = Model.Sum(x => x.DueAmount);
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1000px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #555;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #555;
            padding: 6px;
        }

        table th {
            background: #d0d0d0;
            color: #000;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    .row-due {
        background-color: #f5f5f5;
    }

    .total-row {
        background-color: #333;
        color: #fff;
        font-weight: bold;
    }

    .report-footer {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
        font-size: 13px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .sslPrint {
            display: none !important;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            max-width: 100%;
            margin: 0;
            padding: 10px;
            border: none;
        }

        @@page {
            size: A4 portrait;
            margin: 10mm;
        }

        table {
            font-size: 10px;
            width: 100%;
        }

            table th, table td {
                padding: 3px 4px;
                font-size: 10px;
            }
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right; margin:20px;">
    🖨️ Print
</button>

<div class="report-box">

    <!-- Header -->
    <table style="border:none; margin-bottom:10px;">
        <tr>
            <td style="width:140px; border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px; height:120px;" />
            </td>
            <td style="text-align:right; border:none;">
                <h3 style="margin:0;">@ViewBag.CompanyName</h3>
                <div>@ViewBag.BranchName</div>
            </td>
        </tr>
    </table>

    <hr />

    <!-- Filter Info -->
    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
        <div>
            <strong>Branch:</strong> @ViewBag.BranchName <br />
            <strong>Supplier:</strong> @ViewBag.SupplierName
        </div>
    </div>

    <!-- Title -->
    <h2 style="text-align:center; border-bottom:1px solid #000; padding-bottom:6px;">
        SUPPLIER PAYMENT DUE
    </h2>

    <!-- Table -->
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>SL</th>
                    <th>Supplier Code</th>
                    <th>Supplier Name</th>
                    <th>Due Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int serial = 1;
                    foreach (var item in Model)
                    {
                        <tr class="row-due">
                            <td class="text-center">@serial</td>
                            <td>@item.SupplierCode</td>
                            <td>@item.SupplierName</td>
                            <td class="text-right"
                                data-purchase-amount="@item.PurchaseAmount"
                                data-purchase-count="@item.PurchaseCount"
                                data-payment-amount="@item.TotalPaymentAmount"
                                data-payment-count="@item.PaymentCount"
                                data-last-payment="@item.LastPaymentAmount">
                                @item.DueAmount.ToString("N2")
                            </td>
                        </tr>
                        serial++;
                    }
                    <tr class="total-row">
                        <td colspan="3" class="text-right">Grand Total Due:</td>
                        <td class="text-right">@grandTotalDue.ToString("N2")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No data found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer -->
    <div class="report-footer">
        <div>
            <strong>Printed By:</strong> @(ViewBag.PrintedBy ?? "N/A") |
            <strong>Printed On:</strong> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </div>
        <div>
            <strong>Total Records:</strong> @(Model != null ? Model.Count : 0)
        </div>
    </div>

</div>