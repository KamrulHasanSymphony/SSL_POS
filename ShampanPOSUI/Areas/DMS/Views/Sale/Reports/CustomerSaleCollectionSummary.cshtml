@model List<ShampanPOS.Models.CustomerSaleCollectionReportVM>
@{
    ViewBag.Title = "Customer Sale & Collection Summary";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bd = new System.Globalization.CultureInfo("en-IN");

    var grandSale = Model.Sum(x => x.TotalSaleAmount);
    var grandCollection = Model.Sum(x => x.TotalCollectionAmount);
    var grandOutstanding = Model.Sum(x => x.OutstandingAmount);
}
<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #555;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
        cursor: pointer;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #555;
            padding: 6px;
        }

        table th {
            background: #d0d0d0;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    .total-grand {
        background: #333;
        color: #fff;
        font-weight: bold;
    }

    .report-footer {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-top: 10px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .sslPrint {
            display: none !important;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            max-width: 100%;
            margin: 0;
            padding: 10px;
            border: none;
        }

        @@page {
            size: A4 landscape;
            margin: 10mm;
        }

        table th, table td {
            font-size: 10px;
            padding: 3px 4px;
        }
    }
</style>

<button onclick="window.print()" class="sslPrint">🖨️ Print</button>

<div class="report-box">
    <table style="border:none; margin-bottom:10px;">
        <tr>
            <td style="width:140px; border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png" style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right; border:none;">
                <h3 style="margin:0;">@ViewBag.CompanyName</h3>
                <div>@ViewBag.BranchName</div>
                <div>📞 01612264439</div>
            </td>
        </tr>
    </table>
    <hr />

    <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:11px;">
        <div>
            <strong>Customer:</strong> @ViewBag.CustomerName <br />
            <strong>From Date:</strong> @ViewBag.FromDate
        </div>
        <div style="text-align:right;">
            <strong>To Date:</strong> @ViewBag.ToDate
        </div>
    </div>

    <h2 style="text-align:center; border-bottom:1px solid #000; padding-bottom:6px;">
        CUSTOMER SALE & COLLECTION REPORT (SUMMARY)
    </h2>

    <div style="overflow-x:auto;">
        <table>
            <thead>
                <tr>
                    @*<th>SL</th>
                    <th>Customer Code</th>*@
                    <th>Customer Name</th>
                    <th>Sale Count</th>
                    <th>Total Sale Amount</th>
                    <th>Collection Count</th>
                    <th>Total Collection Amount</th>
                    <th>Outstanding Amount</th>
                    <th>Last Collection Date</th>
                    <th>Last Collection Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int sl = 1;
                    foreach (var item in Model.Where(x => x.SaleCount > 0))
                    {
                        <tr>
                            @*<td class="text-center">@sl</td>
                    <td>@item.CustomerCode</td>*@
                            <td>@item.CustomerName</td>
                            <td class="text-center">@item.SaleCount</td>
                            <td class="text-right">@item.TotalSaleAmount</td>
                            <td class="text-center">@item.CollectionCount</td>
                            <td class="text-right">@item.TotalCollectionAmount</td>
                            <td class="text-right">@item.OutstandingAmount</td>
                            <td class="text-center">@item.LastCollectionDate</td>
                            <td class="text-right">@item.LastCollectionAmount</td>
                        </tr>
                        sl++;
                    }

                    <tr class="total-grand">
                        <td colspan="4" class="text-right">Grand Total:</td>
                        <td class="text-right">@grandSale</td>
                        <td></td>
                        <td class="text-right">@grandCollection</td>
                        <td class="text-right">@grandOutstanding</td>
                        <td colspan="2"></td>
                    </tr>
                }
                else
                {
                    <tr><td colspan="10" class="text-center">No data found</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="report-footer" style="border-top:1px solid #ccc; padding-top:5px;">
        <div>
            <strong>Printed By:</strong> @(ViewBag.PrintedBy ?? "N/A") |
            <strong>Printed On:</strong> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </div>
        @*<div><strong>Total Records:</strong> @(Model?.Count ?? 0)</div>*@
    </div>
</div>