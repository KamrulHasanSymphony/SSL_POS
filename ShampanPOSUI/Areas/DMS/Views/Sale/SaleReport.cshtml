@model ShampanPOS.Models.SaleVM
@{
    ViewBag.Title = "Sale Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 900px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            font-weight: bold;
        }

    .text-right {
        text-align: right;
    }

    /* 🔥 PRINT LIKE SALES REPORT */
    @@media print {

        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
        }

        .sslPrint {
            display: none !important;
        }
    }

    .purchasetotalrow td {
        border: 0 !important
    }
        .purchasetotalrow td span, .double-line {
            border-bottom: 1px solid #000 !important;
            position: relative
        }

            .purchasetotalrow td span::after, .double-line::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -3px;
                width: 100%;
                height: 1px;
                background: #000;
            }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    <i class="k-icon k-i-print"></i> Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">@Model.CompanyName</h3>
                <div style="font-size:16px;">@Model.BranchName</div>
                <div>@Model.BranchAddress 69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>

        </tr>
    </table>

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        INVOICE 
    </h2>

    @*<h3>Sales Information</h3>*@
    <table>
        <tr>
            <th>Sales Code</th>
            <td>@Model.Code</td>
            <th>Invoice Date</th>
            <td style="width: 25%!important">@Model.InvoiceDateTime</td>
        </tr>
        <tr>
            <th>Customer</th>
            <td>@Model.CustomerName</td>
            <th>Sales Order</th>
            <td style="width: 25%!important">@Model.SaleOrderCode</td>
        </tr>
        <tr>
            <th>Delivery Address</th>
            <td colspan="3">@Model.DeliveryAddress</td>
        </tr>

    </table>

    <!-- SALES DETAILS -->
    <h3>Items</h3>
    <table>
        <thead>
            <tr>
                <th style="width:5%!important;" class="text-center">SL</th>
                <th class="text-center">Product</th>
                <th class="text-center">Code</th>
                <th style="width:8%!important;" class="text-center">Qty</th>
                <th style="width:10%!important;" class="text-center">Unit Rate</th>
                <th style="width:10%!important;" class="text-right">Sub Total</th>
                <th style="width:10%!important;" class="text-center">SD Amt</th>
                <th style="width:10%!important;" class="text-center">VAT Amt</th>
                <th style="width:15%!important;" class="text-center">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.saleDetailsList)
            {
                <tr>
                    <td>@item.Line</td>
                    <td>@item.ProductName</td>
                    <td>@item.ProductCode</td>
                    <td class="text-right">@item.Quantity</td>
                    <td class="text-right">@item.UnitRate</td>
                    <td class="text-right">@item.SubTotal</td>
                    <td class="text-right">@item.SDAmount</td>
                    <td class="text-right">@item.VATAmount</td>
                    <td class="text-right">@item.LineTotal</td>
                </tr>
            }

            <!-- FOOTER ROW -->
        <tr class="purchasetotalrow" style="font-weight:bold;">
            <td colspan="2" style="text-align: center;">Total :</td>
            <td></td>
            <td class="text-right"><span>@Model.saleDetailsList.Sum(x => x.Quantity)</span></td>
            <td></td>
            <td class="text-right"><span>@Model.saleDetailsList.Sum(x => x.SubTotal)</span></td>
            <td class="text-right"><span>@Model.saleDetailsList.Sum(x => x.SDAmount)</span></td>
            <td class="text-right"><span>@Model.saleDetailsList.Sum(x => x.VATAmount)</span></td>
            <td class="text-right">@Model.saleDetailsList.Sum(x => x.LineTotal)</td>
        </tr>
        </tbody>
    </table>

    <!-- SUMMARY -->

    <div style="width:300px; margin-left:auto;">

        <div style="display:flex; justify-content:space-between; padding-right: 6px">
            <span>Paid Amount</span>
            <span>@Model.PaidAmount</span>
        </div>

        <!-- LINE -->
        <div style="border-top:1px solid #000; margin:8px 0;"></div>

        @*DUE AMOUNT*@
    <div style="display:flex; justify-content:space-between; font-weight:bold;">
        <span>Due Amount</span>
        <span class="double-line">@Model.DueAmount</span>
    </div>

    </div>

    <!-- COMMENTS -->
    <div style="margin-top:20px;">
        <h5 class="section-title">Comments</h5>
        <div style="margin-top:5px;">
            @Model.Comments
        </div>
    </div>


</div>
