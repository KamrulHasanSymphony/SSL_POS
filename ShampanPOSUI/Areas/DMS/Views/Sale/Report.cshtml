@model ShampanPOS.Models.SaleReportVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    #receipt {
        font-family: 'Courier New', monospace;
        font-size: 12px;
        background: #fff;
    }

        #receipt .receipt {
            width: 320px;
            margin: auto;
            padding: 10px;
        }

    .center {
        text-align: center;
    }

    .right {
        text-align: right;
    }

    .bold {
        font-weight: bold;
    }

    hr {
        border: none;
        border-top: 1px dashed #000;
        margin: 6px 0;
    }

    table {
        width: 100%;
        font-size: 11px;
        border-collapse: collapse;
    }

    td, th {
        padding: 3px 0;
    }

    .print-btn {
        text-align: center;
        margin: 10px 0;
    }

    @@media print {
        .main-sidebar, .navbar, .content-header, .main-header, .footer {
            display: none !important;
        }

        body * {
            visibility: hidden;
        }

        #receipt, #receipt * {
            visibility: visible;
        }

        #receipt {
            position: absolute;
            left: 50%;
            top: 0;
            transform: translateX(-50%);
            width: 320px;
        }

        .print-btn {
            display: none !important;
        }
    }
</style>

<div id="receipt">
    <div class="receipt">

        <!-- HEADER -->
        <div class="center">
            <div style="font-size:16px;" class="bold">@Model.CompanyName</div>
            <div>@Model.BranchName</div>
            <div>@Model.BranchAddress</div>
            <div>📞 01612264439</div>
            <div>✉️ symphonysorftech1999@gamil.com</div>
        </div>

        <hr />

        <div class="center bold">Paid Bill</div>

        <hr />

        <!-- DATE & TIME -->
        <table>
            <tr>
                <td>Date: @DateTime.Parse(Model.InvoiceDateTime).ToString("dd/MM/yyyy")</td>
                <td class="right">Time: @DateTime.Now.ToString("hh:mm tt")</td>
            </tr>
        </table>

        <table>
            <tr>
                <td>Invoice No:</td>
                <td class="right">@Model.Code</td>
            </tr>
            @*<tr>
                <td>Customer:</td>
                <td class="right">@Model.CustomerName</td>
            </tr>*@
        </table>

        <hr />

        <!-- ITEMS HEADER -->
        <table>
            <tr class="bold">
                <td>Item</td>
                <td class="right">Qty</td>
                <td class="right">Price</td>
                <td class="right">Total</td>
            </tr>
        </table>

        <hr />

        <!-- ITEMS -->
        <table>
            @foreach (var item in Model.saleDetailsList)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td class="right">@item.Quantity</td>
                    <td class="right">@item.UnitRate</td>
                    <td class="right">@item.LineTotal</td>
                </tr>
            }
        </table>

        <hr />

        <!-- TOTALS -->
        <table>
            <tr>
                <td class="bold">Net Total</td>
                <td class="right">@Model.SubTotal</td>
            </tr>
            @*<tr>
                <td class="bold">Round Off</td>
                <td class="right">0.00</td>
            </tr>*@
            <tr>
                <td class="bold">Grand Total</td>
                <td class="right">@Model.GrandTotal</td>
            </tr>
        </table>

        <hr />

        <!-- PAYMENT -->
        <table>
            <tr>
                <td>Payment (Cash)</td>
                <td class="right">@Model.PaidAmount</td>
            </tr>
            <tr>
                <td>Due</td>
                <td class="right">@Model.DueAmount</td>
            </tr>
        </table>

        <hr />

        <!-- NOTE -->
        <div class="center">
            <small>@Model.Comments</small>
        </div>

        <hr />

        <!-- FOOTER -->
        <div class="center">
            <div>Thank You!</div>
            <div>Please Visit Again</div>
        </div>

        <div class="print-btn">
            <button onclick="window.print()">🖨 Print</button>
        </div>

    </div>
</div>