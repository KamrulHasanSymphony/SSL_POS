@model List<ShampanPOS.Models.PurchaseOrderReportVM>

@{
    ViewBag.Title = "Purchase Order";
    Layout = "~/Views/Shared/_Layout.cshtml";

    //string reportType = "Day Wise";
}

@{
    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;
}
<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin: 10px 0;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }
</style>

<button onclick="window.print()" class="sslPrint">Print</button>

<div class="report-box">

    <!-- ================= HEADER ================= -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>

            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">
                    @ViewBag.CompanyName
                </h3>

                <div>
                    @ViewBag.BranchName
                </div>

                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>
        </tr>
    </table>

    <hr />

    <!-- ================= FILTER INFO ================= -->
    <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
        <div>
            <strong>Supplier:</strong> @ViewBag.SupplierName <br />
            <strong>Order From:</strong> @ViewBag.OrderFromDate
        </div>

        <div style="text-align:right;">
            <strong>Product:</strong> @ViewBag.ProductName <br />
            <strong>Order To:</strong> @ViewBag.OrderToDate
        </div>
    </div>

    <h3 style="text-align:center;border-bottom:1px solid #000;">
        @ViewBag.ReportTitle
    </h3>

    <!-- ================= TABLE ================= -->
    <table>

        <thead>
            <tr>

                @if (isSummary)
                {
                    <th>Order Code</th>
                    <th>Order Date</th>
                    <th>Delivery Date</th>
                    <th>Supplier</th>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Total</th>
                }
                else
                {
                    <th>Order Code</th>
                    <th>Order Date</th>
                    <th>Delivery Date</th>
                    <th>Supplier</th>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Sub Total</th>
                    <th>SD Amount</th>
                    <th>VAT Amount</th>
                    <th>Total</th>
                }

            </tr>
        </thead>

        @using System.Globalization
        @{
            var bd = new CultureInfo("en-IN");
        }

        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>

                        @if (isSummary)
                        {
                            <td>@item.Code</td>
                            <td>@item.OrderDate</td>
                            <td>@item.DeliveryDateTime</td>
                            <td>@item.SupplierName</td>
                            <td>@item.ProductName</td>

                            <td class="text-right">
                                @item.Quantity
                            </td>

                            <td class="text-right">
                                <b>@((item.LineTotal ?? 0).ToString("N2", bd))</b>
                            </td>
                        }
                        else
                        {
                            <td>@item.Code</td>
                            <td>@item.OrderDate</td>
                            <td>@item.DeliveryDateTime</td>
                            <td>@item.SupplierName</td>
                            <td>@item.ProductName</td>

                            <td class="text-right">
                                @item.Quantity
                            </td>

                            <td class="text-right">
                                @((item.UnitPrice ?? 0).ToString("N2", bd))
                            </td>

                            <td class="text-right">
                                @((item.SubTotal ?? 0).ToString("N2", bd))
                            </td>

                            <td class="text-right">
                                @((item.SDAmount ?? 0).ToString("N2", bd))
                            </td>

                            <td class="text-right">
                                @((item.VATAmount ?? 0).ToString("N2", bd))
                            </td>
                            <td class="text-right">
                                <b>@((item.LineTotal ?? 0).ToString("N2", bd))</b>
                            </td>
                        }

                    </tr>
                }

        <tr style="font-weight:bold;background:#f1f1f1;">

            @if (isSummary)
            {
                <td>Total</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>

                <td class="text-right">
                    @Model.Sum(x => x.Quantity)
                </td>

                <td class="text-right">
                    @(Model.Sum(x => x.LineTotal ?? 0).ToString("N2", bd))
                </td>
            }
            else
            {
                <td>Total</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>

                <td class="text-right">
                    @Model.Sum(x => x.Quantity)
                </td>

                <td></td>

                <td class="text-right">
                    @(Model.Sum(x => x.SubTotal ?? 0).ToString("N2", bd))
                </td>

                <td class="text-right">
                    @(Model.Sum(x => x.SDAmount ?? 0).ToString("N2", bd))
                </td>
                <td class="text-right">
                    @(Model.Sum(x => x.VATAmount ?? 0).ToString("N2", bd))
                </td>
                <td class="text-right">
                    @(Model.Sum(x => x.LineTotal ?? 0).ToString("N2", bd))
                </td>
            }

        </tr>
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;">
                        No data found
                    </td>
                </tr>
            }

        </tbody>

    </table>
            else
            {
                <tr>
                    <td colspan="6" style="text-align:center;">
                        No data found
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>