@model ShampanPOS.Models.PurchaseReportVM
@{
    ViewBag.Title = "Purchase Return vs Purchase Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .k-filter-input {
        height: 23px;
        padding: 4px 8px;
        border: 1px solid #c5c5c5;
        border-radius: 4px;
        background-color: #ffffff;
        font-size: 13px;
        color: #444;
    }

        .k-filter-input:focus {
            border-color: #2a9fd6;
            box-shadow: 0 0 3px rgba(42, 159, 214, 0.4);
            outline: none;
        }
</style>
<!-- ================= HEADER ================= -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">

            <div class="col-sm-6">
                <h1 class="m-0">Purchase Return vs Purchase Report</h1>
            </div>

            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li id="btnBack">
                        <img src="~/Content/css/ButtonsIcons/back-icon.png"
                             title="Click for Go Back" />
                    </li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="accordion" id="reportFilterAccordion">
        <div class="card">

            <div class="card-body p-2">

                <div class="form-group row">

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.SupplierId)
                        <div class="input-group ">
                            @Html.TextBoxFor(model => model.SupplierId,
                                new { @class = "required form-control form-control-sm", @style = "width: 100%;" })
                        </div>
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.PurchaseFromDate)
                        <div class="d-flex align-items-center">
                            @Html.TextBoxFor(model => model.PurchaseFromDate,
                                new { @class = "form-control form-control-sm kendoDatePicker", @id = "PurchaseFromDate" })
                            <input type="checkbox" id="chkPurchaseFromDate" style="margin-left:6px;" />
                        </div>
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.PurchaseToDate)
                        <div class="d-flex align-items-center">
                            @Html.TextBoxFor(model => model.PurchaseToDate,
                                new { @class = "form-control form-control-sm kendoDatePicker", @id = "PurchaseToDate" })
                            <input type="checkbox" id="chkPurchaseToDate" style="margin-left:6px;" />
                        </div>
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.InvoiceFromDate)
                        <div class="d-flex align-items-center">
                            @Html.TextBoxFor(model => model.InvoiceFromDate,
                                new { @class = "form-control form-control-sm kendoDatePicker", @id = "InvoiceFromDate" })
                            <input type="checkbox" id="chkInvoiceFromDate" style="margin-left:6px;" />
                        </div>
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.InvoiceToDate)
                        <div class="d-flex align-items-center">
                            @Html.TextBoxFor(model => model.InvoiceToDate,
                                new { @class = "form-control form-control-sm kendoDatePicker", @id = "InvoiceToDate" })
                            <input type="checkbox" id="chkInvoiceToDate" style="margin-left:6px;" />
                        </div>
                    </div>

                </div>


                <div class="form-group row">

                    <div class="col-sm-2">
                        <label>Product</label>

                        <div class="input-group input-group-sm">

                            <input type="text"
                                   id="ProductName"
                                   class="form-control"
                                   placeholder="Select Product"
                                   readonly />

                            <input type="hidden" id="ProductId" />

                            <div class="input-group-append">

                                <button type="button"
                                        id="btnClearProduct"
                                        class="btn btn-warning"
                                        onclick="ClearProduct()">
                                    ✖
                                </button>

                                <button type="button"
                                        id="btnProductSearch"
                                        class="btn btn-primary">
                                    <i class="fa fa-search"></i>
                                </button>

                            </div>

                        </div>
                    </div>

                    <div class="col-sm-2">
                        <label>Purchase</label>

                        <div class="input-group input-group-sm">

                            <input type="text"
                                   id="PurchaseCode"
                                   class="form-control"
                                   placeholder="Select Purchase"
                                   readonly />

                            <input type="hidden" id="PurchaseId" />

                            <div class="input-group-append">

                                <button type="button"
                                        id="btnClearPurchase"
                                        class="btn btn-warning"
                                        onclick="ClearPurchase()">
                                    ✖
                                </button>

                                <button type="button"
                                        id="btnPurchaseSearch"
                                        class="btn btn-primary">
                                    <i class="fa fa-search"></i>
                                </button>

                            </div>

                        </div>
                    </div>

                    <div class="col-sm-2">
                        <label>Purchase Return</label>

                        <div class="input-group input-group-sm">

                            <input type="text"
                                   id="PurchaseReturnCode"
                                   class="form-control"
                                   placeholder="Select Purchase Return"
                                   readonly />

                            <input type="hidden" id="PurchasesReturnId" />

                            <div class="input-group-append">

                                <button type="button"
                                        id="btnClearPurchaseReturn"
                                        class="btn btn-warning"
                                        onclick="ClearPurchaseReturn()">
                                    ✖
                                </button>

                                <button type="button"
                                        id="btnPurchaseReturnSearch"
                                        class="btn btn-primary">
                                    <i class="fa fa-search"></i>
                                </button>

                            </div>

                        </div>
                    </div>

                    <div class="col-sm-2 d-flex flex-column">

                        <!-- ✅ Custom Label -->
                        <label for="IsSummary">Summary</label>

                        <div class="Onoffbtn">
                            <div class="input-group" style="width: 78%;">

                                <!-- Hidden field ensures false value is posted when unchecked -->
                                <input type="hidden" name="IsSummary" value="false" />

                                <!-- Bootstrap Switch Checkbox -->
                                <input id="IsSummary"
                                       name="IsSummary"
                                       type="checkbox"
                                       value="true"
                                       @(Model.IsSummary ? "checked=\"checked\"" : "")
                                       data-bootstrap-switch
                                       data-off-color="danger"
                                       data-on-color="success"
                                       data-on-text="True"
                                       data-off-text="False" />

                            </div>
                        </div>

                    </div>

                </div>

                <div class="row">
                    <div class="col-sm-2 offset-sm-0 pt-2">
                        <button type="button"
                                class="btn btn-success btn-sm"
                                onclick="PrintPurchaseReport()">
                            <i class="fas fa-print"></i> Print
                        </button>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>


<div id="purchaseDetailsWindow" style="display:none; padding:10px;">

    <div style="display:flex; gap:10px; margin-bottom:10px;">
        <input id="ProductGroupId" style="width:35%;" placeholder="Group" />
        <input id="FilterProductCode" class="k-filter-input" style="width:20%;" placeholder="Product Code" />
        <input id="FilterProductName" class="k-filter-input" style="width:45%;" placeholder="Product Name" />
    </div>

    <div id="purchaseDetailsGrid"></div>

</div>

<div id="purchaseWindow" style="display:none; padding:10px;">

    <div style="display:flex; gap:10px; margin-bottom:10px;">
        <input id="PurchaseSupplierId" style="width:40%;" placeholder="Supplier" />
        <input id="PurCode" class="k-filter-input" style="width:30%;" placeholder="Purchase Code" />
        <input id="FilterPurchaseDate" class="k-filter-input" style="width:30%;" placeholder="Purchase Date" />
    </div>

    <!-- Purchase List Grid -->
    <div id="purchaseGrid"></div>
</div>


<div id="purchaseReturnWindow" style="display:none; padding:10px;">

    <div style="display:flex; gap:10px; margin-bottom:10px;">
        <input id="PurchaseReturnSupplierId" style="width:40%;" placeholder="Supplier" />
        <input id="FilterCode" class="k-filter-input" style="width:30%;" placeholder="Return Code" />
        <input id="FilterInvoiceDate" style="width:30%;" placeholder="Invoice Date" />
    </div>

    <div id="purchaseReturnGrid"></div>
</div>
<!-- ================= SCRIPT ================= -->
@section scripts{

    <script src="~/Areas/Common/js/Services/CommonService.js"></script>
    <script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>

    <script>

    var getSupplierId = 0;

    $(document).ready(function () {

        getSupplierId = $("#SupplierId").val() || 0;
        $("[data-bootstrap-switch]").bootstrapSwitch();

        GetSupplierComboBox();
        // Kendo DatePickers
        $("#PurchaseFromDate").kendoDatePicker({
            format: "yyyy-MM-dd"
        });
        $("#PurchaseToDate").kendoDatePicker({
            format: "yyyy-MM-dd"
        });
        //$("#PurchaseToDate").kendoDatePicker();
        $("#InvoiceFromDate").kendoDatePicker({
            format: "yyyy-MM-dd"
        });
        $("#InvoiceToDate").kendoDatePicker({
            format: "yyyy-MM-dd"
        });
        var currentDate = new Date();

        $("#PurchaseFromDate").data("kendoDatePicker").value(currentDate);
        $("#PurchaseToDate").data("kendoDatePicker").value(currentDate);
        $("#InvoiceFromDate").data("kendoDatePicker").value(currentDate);
        $("#InvoiceToDate").data("kendoDatePicker").value(currentDate);


        // Purchase Date Validation
        // ================================

        var purchaseFromPicker = $("#PurchaseFromDate").data("kendoDatePicker");
        var purchaseToPicker = $("#PurchaseToDate").data("kendoDatePicker");

        purchaseFromPicker.bind("change", function () {

            var fromDate = purchaseFromPicker.value();
            var toDate = purchaseToPicker.value();

            if (fromDate) {
                purchaseToPicker.min(fromDate);
            }

            if (fromDate && toDate && fromDate > toDate) {

                purchaseToPicker.value(fromDate);

                ShowNotification(3, "From Date cannot be greater than To Date");
            }
        });

        purchaseToPicker.bind("change", function () {

            var fromDate = purchaseFromPicker.value();
            var toDate = purchaseToPicker.value();

            if (toDate) {
                purchaseFromPicker.max(toDate);
            }

            if (fromDate && toDate && fromDate > toDate) {

                purchaseFromPicker.value(toDate);

                ShowNotification(3, "From Date cannot be greater than To Date");
            }
        });


        // Invoice Date Validation
        // ================================

        var invoiceFromPicker = $("#InvoiceFromDate").data("kendoDatePicker");
        var invoiceToPicker = $("#InvoiceToDate").data("kendoDatePicker");

        invoiceFromPicker.bind("change", function () {

            var fromDate = invoiceFromPicker.value();
            var toDate = invoiceToPicker.value();

            if (fromDate) {
                invoiceToPicker.min(fromDate);
            }

            if (fromDate && toDate && fromDate > toDate) {

                invoiceToPicker.value(fromDate);

                ShowNotification(3, "From Date cannot be greater than To Date");
            }
        });

        invoiceToPicker.bind("change", function () {

            var fromDate = invoiceFromPicker.value();
            var toDate = invoiceToPicker.value();

            if (toDate) {
                invoiceFromPicker.max(toDate);
            }

            if (fromDate && toDate && fromDate > toDate) {

                invoiceFromPicker.value(toDate);

                ShowNotification(3, "From Date cannot be greater than To Date");
            }
        });



    });

     $("#btnProductSearch").on("click", function () {
        OpenProductPopup(null);
    });

    function OpenProductPopup(detailRow) {

            var wnd = $("#purchaseDetailsWindow").data("kendoWindow");

            if (!wnd) {
                $("#purchaseDetailsWindow").kendoWindow({
                    width: "700px",
                    height: "500px",
                    title: "Select Product",
                    modal: true,
                    visible: false
                });
                wnd = $("#purchaseDetailsWindow").data("kendoWindow");
            }

            wnd.center().open();

            // Clear previous filters
            $("#FilterProductCode").val("");
            $("#FilterProductName").val("");

            // Load Product Group Combo
            GetProductGroupComboBox();

            // Rebuild Grid
            $("#purchaseDetailsGrid").empty();

            $("#purchaseDetailsGrid").kendoGrid({

                dataSource: {
                    transport: {
                        read: {
                            url: "/Common/Common/GetProductModal",
                            dataType: "json"
                        }
                    },
                   pageSize: 10
                },

                pageable: true,
                filterable: true,
                selectable: "row",
                //toolbar: ["search"],
                searchable: true,


                columns: [
                    { field: "ProductId", hidden: true },
                    { field: "ProductCode", title: "Product Code" },
                    { field: "ProductName", title: "Product Name" },
                    { field: "UOMName", title: "UOM" },
                    { field: "ProductGroupName", title: "Group" },
                    { field: "PurchasePrice", title: "Price" }
                ]

            });

            // Product Code Search
            $("#FilterProductCode")
                .off("input")
                .on("input", function () {
                    applyProductGroupFilter();
                });

            // Product Name Search
            $("#FilterProductName")
                .off("input")
                .on("input", function () {
                    applyProductGroupFilter();
                });

            // Select Product
            $("#purchaseDetailsGrid")
                .off("dblclick")
                .on("dblclick", "tr", function () {

                    var grid = $("#purchaseDetailsGrid").data("kendoGrid");
                    var item = grid.dataItem($(this));

                    if (!item) return;

                    ApplyProductSelection(detailRow, item);

                    wnd.close();
                });
        }

    function LoadItemsGrid() {
        $("#items").kendoListView({
            dataSource: {
                transport: {
                    read: {
                        url: "/Common/Common/GetProductModal",
                        dataType: "json"
                    }
                }
            },

            template: `
        <div class="item-card">

            <h5>#: Name #</h5>

            <div class="item-image">
                <img src="#: Image #" alt="#: Name #" />
            </div>

            <div class="item-info">
                <div><b>UOM:</b> #: UomName #</div>
                <div><b>Cost:</b> #: kendo.toString(PurchasePrice,'n2') #</div>
                <div><b>VAT:</b> #: VATRate # %</div>
                <div><b>SD:</b> #: SDRate # %</div>
            </div>


            <div class="card-actions">
                <input type='number' class='qty' value='1' min='1' />
                <button class='addToCart'
                        data-id='#: Id #'
                        data-code='#: Code #'
                        data-name='#: Name #'
                        data-uom='#: UomName #'
                        data-uomid='#: UomId #'
                        data-price='#: PurchasePrice #'
                        data-vat='#: VATRate #'
                        data-sd='#: SDRate #'>
                    Add
                </button>
            </div>

        </div>
        `,

            dataBound: function () {
                $(".addToCart").off("click").on("click", function () {

                    var item = {
                        Id: $(this).data("id"),
                        Code: $(this).data("code"),
                        Name: $(this).data("name"),
                        UomId: $(this).data("uomid"),
                        UomName: $(this).data("uom"),
                        PurchasePrice: $(this).data("price"),
                        VATRate: $(this).data("vat"),
                        SDRate: $(this).data("sd"),
                        Quantity: $(this).closest(".item-card").find(".qty").val()
                    };

                    AddItemToSaleDetails(item);
                });
            }
        });
    }


    function AddItemToSaleDetails(item) {

        var grid = $("#saleDetails").data("kendoGrid");

        var detailRow = grid.dataSource.add({
            ProductId: item.Id,
            ProductCode: item.Code,
            ProductName: item.Name,
            UOMId: item.UomId,
            UOMName: item.UomName,
            Quantity: parseFloat(item.Quantity),
            UnitRate: parseFloat(item.PurchasePrice),
            VATRate: item.VATRate || 0,
            SD: item.SD || 0
        });

        var qty = detailRow.Quantity || 0;
        var unit = detailRow.UnitRate || 0;
        var sdRate = detailRow.SD || 0;
        var vatRate = detailRow.VATRate || 0;

        var subTotal = qty * unit;
        detailRow.set("SubTotal", subTotal);

        var sdAmount = (subTotal * sdRate) / 100;
        detailRow.set("SDAmount", sdAmount);

        var vatAmount = ((subTotal + sdAmount) * vatRate) / 100;
        detailRow.set("VATAmount", vatAmount);

        var total = subTotal + sdAmount + vatAmount;
        detailRow.set("LineTotal", total);

        grid.refresh();
    }

    function ApplyProductSelection(detailRow, item) {

        console.log(item);

        // ✅ MASTER FIELD CASE
        if (!detailRow) {
            $("#ProductId").val(item.ProductId);
            $("#ProductName").val(item.ProductName);
            return;
        }

        // ✅ DETAILS GRID CASE
        detailRow.set("ProductId", item.ProductId);
        detailRow.set("ProductCode", item.ProductCode);
        detailRow.set("ProductName", item.ProductName);

        detailRow.set("UOMId", item.UOMId);
        detailRow.set("UOMName", item.UOMName);

        detailRow.set("UnitRate", item.PurchasePrice);

        detailRow.set("VATRate", item.VATRate);
        detailRow.set("SD", item.SDRate);

        if (!detailRow.Quantity || detailRow.Quantity <= 0) {
            detailRow.set("Quantity", 1);
        }

        var subTotal = detailRow.Quantity * item.PurchasePrice;
        detailRow.set("SubTotal", subTotal);

        var sdAmt = (subTotal * (item.SDRate || 0)) / 100;
        detailRow.set("SDAmount", sdAmt);

        var vatAmt = ((subTotal + sdAmt) * (item.VATRate || 0)) / 100;
        detailRow.set("VATAmount", vatAmt);

        detailRow.set("LineTotal", subTotal + sdAmt + vatAmt);
    }


    function GetProductGroupComboBox() {

        $("#ProductGroupId").kendoMultiColumnComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            height: 300,

            columns: [
                { field: "Code", title: "Code", width: 130 },
                { field: "Name", title: "Name", width: 150 }
            ],

            filter: "contains",
            filterFields: ["Code", "Name"],

            dataSource: {
                transport: {
                    read: "/Common/Common/GetProductGroupList"
                }
            },

            placeholder: "Select Product Group",

            change: function () {
                applyProductGroupFilter(); 
            }
        });
    }

    function applyProductGroupFilter() {
            debugger;
            var combo = $("#ProductGroupId").data("kendoMultiColumnComboBox");
            var groupId = combo ? combo.value() : "";

            var productCode = $("#FilterProductCode").val().trim();
            var productName = $("#FilterProductName").val().trim();

            var grid = $("#purchaseDetailsGrid").data("kendoGrid");

            if (!grid) return;

            var filters = [];

            // Product Group
            if (groupId && groupId !== "") {
                filters.push({
                    field: "ProductGroupId",
                    operator: "eq",
                    value: parseInt(groupId)
                });
            }

            // Product Code
            if (productCode && productCode.trim().length >= 3) {
                filters.push({
                    field: "ProductCode",
                    operator: "contains",
                    value: productCode.trim()
                });
            }

            // Product Name
            if (productName && productName.trim().length >= 3) {
                filters.push({
                    field: "ProductName",
                    operator: "contains",
                    value: productName.trim()
                });
            }

            if (filters.length > 0) {
                grid.dataSource.filter({
                    logic: "and",
                    filters: filters
                });
            } else {
                grid.dataSource.filter({});
            }
        }

   //Purchase

    $("#btnPurchaseSearch").on("click", function () {
            OpenPurchasePopup();
        });

    function OpenPurchasePopup() {

            var wnd = $("#purchaseWindow").data("kendoWindow");

            if (!wnd) {
                $("#purchaseWindow").kendoWindow({
                    width: "900px",
                    height: "550px",
                    title: "Select Purchase",
                    modal: true,
                    visible: false
                });

                wnd = $("#purchaseWindow").data("kendoWindow");
            }

            wnd.center().open();

        LoadSupplierCombo();
        // Clear previous filters

        $("#PurchaseCode").val("");
        $("#FilterPurchaseDate").val("");


            $("#purchaseGrid").kendoGrid({
                dataSource: {
                    transport: {
                        read: {
                            url: "/Common/Common/GetPurchaseModal",
                            dataType: "json"
                        },
                    },
                  pageSize: 10
                },

                pageable: true,
                filterable: true,
                selectable: "row",
                searchable: true,

                columns: [
                    { field: "Code", title: "Purchase Code", width: "150px" },
                    { field: "SupplierName", title: "Supplier", width: "180px" },
                    { field: "PurchaseDateString", title: "Purchase Date", width: "120px" },
                    { field: "Quantity", title: "Quantity", width: "120px" },
                    { field: "UnitPrice", title: "Unit Price", width: "120px" },
                    { field: "GrandTotal", title: "Total", width: "120px" }
                ]
            });

        // Purchase Code filter
        $("#PurCode")
            .off("input")
            .on("input", function () {
                applySupplierFilter();
            });

        // Purchase Date filter
        $("#FilterPurchaseDate")
            .off("change")
            .on("change", function () {
                applySupplierFilter();
            });

            // double click select
            $("#purchaseGrid").off("dblclick").on("dblclick", "tr", function () {

                var grid = $("#purchaseGrid").data("kendoGrid");
                var item = grid.dataItem($(this));

                ApplyPurchaseSelection(item);
                wnd.close();
            });
        }

    function ApplyPurchaseSelection(item) {

        console.log(item);

        $("#PurchaseId").val(item.Id);
        $("#PurchaseCode").val(item.Code);
        $("#SupplierName").val(item.SupplierName);

        $("#PurchaseDate").val(kendo.toString(item.PurchaseDate, "yyyy-MM-dd"));

        $("#SubTotal").val(item.SubTotal);
        $("#TotalSD").val(item.TotalSD);
        $("#TotalVAT").val(item.TotalVAT);
        $("#GrandTotal").val(item.GrandTotal);
        $("#PaidAmount").val(item.PaidAmount);
    }

    function LoadSupplierCombo() {

        $("#PurchaseSupplierId").kendoComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            placeholder: "Select Supplier",
            filter: "contains",

            dataSource: {
                transport: {
                    read: "/Common/Common/GetSupplierList"
                }
            },

            change: applySupplierFilter,
            select: applySupplierFilter
        });
    }

    function applySupplierFilter() {

            var combo = $("#PurchaseSupplierId").data("kendoComboBox");
            var supplierId = combo ? combo.value() : "";

            var purchaseCode = $("#PurCode").val().trim();
            var purchaseDate = $("#FilterPurchaseDate").val();

            var grid = $("#purchaseGrid").data("kendoGrid");

            if (!grid) return;

            var filters = [];

            // Supplier
            if (supplierId && supplierId !== "") {
                filters.push({
                    field: "SupplierId",
                    operator: "eq",
                    value: parseInt(supplierId)
                });
            }

            if (purchaseCode && purchaseCode.length >= 3) {
                filters.push({
                    field: "Code",
                    operator: "contains",
                    value: purchaseCode
                });
            }

            // Purchase Date
            if (purchaseDate && purchaseDate !== "") {
                filters.push({
                    field: "PurchaseDateString",
                    operator: "eq",
                    value: purchaseDate
                });
            }

            if (filters.length > 0) {
                grid.dataSource.filter({
                    logic: "and",
                    filters: filters
                });
            } else {
                grid.dataSource.filter({});
            }
        }

    // Purchase Return

        $("#btnPurchaseReturnSearch").on("click", function () {
            OpenPurchaseReturnPopup();
        });

     function OpenPurchaseReturnPopup() {

            var wnd = $("#purchaseReturnWindow").data("kendoWindow");

            if (!wnd) {
                $("#purchaseReturnWindow").kendoWindow({
                    width: "900px",
                    height: "550px",
                    title: "Select Purchase Return",
                    modal: true,
                    visible: false
                });

                wnd = $("#purchaseReturnWindow").data("kendoWindow");
            }

            wnd.center().open();

            $("#FilterCode").val("");
            //$("#FilterInvoiceDate").val("");
            $("#FilterInvoiceDate").kendoDatePicker({
                 format: "yyyy-MM-dd"
             });
            LoadPurchaseReturnSupplierCombo();

            $("#purchaseReturnGrid").empty();

            $("#purchaseReturnGrid").kendoGrid({

                dataSource: {
                    transport: {
                        read: {
                            url: "/Common/Common/GetPurchaseReturnModal",
                            dataType: "json"
                        }
                    },
                    pageSize: 10
                },

                pageable: true,
                filterable: true,
                selectable: "row",
                searchable: true,

                columns: [
                    { field: "Code", title: "Return Code", width: "150px" },
                    { field: "SupplierName", title: "Supplier", width: "180px" },
                    { field: "Quantity", title: "Quantity", width: "120px" },
                    { field: "UnitPrice", title: "Unit Price", width: "120px" },
                    { field: "LineTotal", title: "Total", width: "120px" },
                    {
                        field: "InvoiceDateTime",
                        title: "Invoice Date",
                        width: "150px",
                        format: "{0:yyyy-MM-dd}"
                    }
                ]
            });

            // Return Code Search

            $("#FilterCode")
                .off("input")
                .on("input", function () {
                    applyPurchaseReturnSupplierFilter();
                });


         // Purchase Date filter
         $("#FilterInvoiceDate")
             .off("change")
             .on("change", function () {
                 applyPurchaseReturnSupplierFilter();
             });

            // Select Purchase Return

            $("#purchaseReturnGrid")
                .off("dblclick")
                .on("dblclick", "tr", function () {

                    var grid = $("#purchaseReturnGrid").data("kendoGrid");
                    var item = grid.dataItem($(this));

                    if (!item) return;

                    ApplyPurchaseReturnSelection(item);

                    wnd.close();
                });
        }

     function ApplyPurchaseReturnSelection(item) {

            console.log(item);

            $("#PurchasesReturnId").val(item.Id);
            $("#PurchaseReturnCode").val(item.Code);

            $("#SupplierName").val(item.SupplierName);

            $("#InvoiceDateTime").val(kendo.toString(item.InvoiceDateTime, "yyyy-MM-dd"));


            $("#LineTotal").val(item.LineTotal);
        }

    function LoadPurchaseReturnSupplierCombo() {
        $("#PurchaseReturnSupplierId").kendoComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            placeholder: "Select Supplier",
            filter: "contains",
            dataSource: {
                transport: {
                    read: "/Common/Common/GetSupplierList"
                }
            },
            change: applyPurchaseReturnSupplierFilter,
            select: applyPurchaseReturnSupplierFilter
        });
    }

    function applyPurchaseReturnSupplierFilter() {
        var combo = $("#PurchaseReturnSupplierId").data("kendoComboBox");
        var supplierId = combo ? combo.value() : "";

        var returnCode = $("#FilterCode").val().trim();
        var invoiceDate = $("#FilterInvoiceDate").val();
        var grid = $("#purchaseReturnGrid").data("kendoGrid");
        if (!grid) return;

        var filters = [];

        // Supplier Filter
        if (supplierId && supplierId !== "") {
            filters.push({
                field: "SupplierId",
                operator: "eq",
                value: parseInt(supplierId)
            });
        }

        // Return Code Filter 
        if (returnCode && returnCode.length >= 3) {
            filters.push({
                field: "Code",
                operator: "contains",
                value: returnCode
            });
        }

        // Return Date Filter
        if (invoiceDate && invoiceDate !== "") {
            filters.push({
                field: "InvoiceDateTime",
                operator: "eq",
                value: invoiceDate
            });
        }

        if (filters.length > 0) {
            grid.dataSource.filter({
                logic: "and",
                filters: filters
            });
        } else {
            grid.dataSource.filter({});
        }
    }

