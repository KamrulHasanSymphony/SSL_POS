@model List<ShampanPOS.Models.SaleReportVM>
@{
    ViewBag.Title = "Sale vs Sale Return Summary";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;margin-bottom:10px;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;"> @ViewBag.CompanyName </h3>
                <div> @ViewBag.BranchName </div>
                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>
        </tr>
    </table>

    <!-- TITLE -->
    <h2 style="text-align:center;border-bottom:1px solid #000;">
        SALE VS SALE RETURN REPORT (@(isSummary ? "SUMMARY" : "DETAILS"))
    </h2>

    @using System.Globalization
    @{
        var bd = new CultureInfo("en-IN");
    }

    <div class="table-responsive">
        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Customer</th>

                    <th>Sale No</th>

                    <th>Product</th>

                    <th>Sale Return No</th>

                    <th>Sale Qty</th>
                    <th>Sale Amount</th>

                    <th>Return Qty</th>
                    <th>Return Amount</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.CustomerName (@item.CustomerCode)
                            </td>

                            <td>@item.Code</td>

                            <td>@item.ProductName (@item.ProductCode)</td>

                            <td> @item.SaleReturnNo</td>

                            <td class="text-right">@item.SaleQty</td>

                            <td class="text-right">@((Model.Sum(x => x.SaleAmount) ?? 0).ToString("N2", bd))</td>

                            <td class="text-right">
                                @item.SaleReturnQty
                            </td>

                            <td class="text-right">@((Model.Sum(x => x.SaleReturnAmount) ?? 0).ToString("N2", bd))  </td>

                        </tr>
                    }

                    <tr style="font-weight:bold;background:#f1f1f1;">

                        <td colspan="4">
                            Total
                        </td>

                        <td class="text-right">@Model.Sum(x => x.SaleQty)</td>

                        <td class="text-right">@((Model.Sum(x => x.SaleAmount) ?? 0).ToString("N2", bd))</td>

                        <td class="text-right">@Model.Sum(x => x.SaleReturnQty)</td>

                        <td class="text-right">@((Model.Sum(x => x.SaleReturnAmount) ?? 0).ToString("N2", bd))  </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:20px;">
                            No sale data found
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>

</div>