@model List<ShampanPOS.Models.PurchaseReportVM>

@{
    ViewBag.Title = "Purchase Return vs Purchase Summary";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1000px;
        margin: 20px auto;
        border-radius: 6px;
        overflow-x: auto;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    /* ================= TABLE ================= */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        table-layout: auto;
        white-space: nowrap;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    /* ================= SCROLL SUPPORT ================= */
    .table-responsive {
        overflow-x: auto;
    }

    /* ================= PRINT STYLE ================= */
    @@media print {

        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 1000px; /* same as screen */
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
            overflow: visible;
        }

        .sslPrint {
            display: none !important;
        }
        /* Optional: remove scroll effect in print */
        .table-responsive {
            overflow: visible !important;
        }
    }
</style>
<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;margin-bottom:10px;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">Symphony Softtech Limited</h3>
                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>
        </tr>
    </table>

    <!-- TITLE -->
    <h2 style="text-align:center;border-bottom:1px solid #000;">
        PURCHASE REPORT (@(isSummary ? "SUMMARY" : "DETAILS"))
    </h2>

    @using System.Globalization
    @{
        var bd = new CultureInfo("en-IN");
    }
    <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Purchase No</th>
                    <th>Purchase Return No</th>
                    <th>Supplier Code</th>
                    <th>Supplier Name</th>
                    <th>Product Code</th>
                    <th>Product Name</th>
                    <th>Invoice Date</th>
                    <th>Purchase Date</th>

                    <th>Quantity</th>

                    @if (!isSummary)
                    {
                        <th>Unit Price</th>
                        <th>SD</th>
                    }

                    <th>Sub Total</th>
                    <th>VAT Amount</th>
                    <th>Line Total</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.PurchaseReturnNo</td>
                            <td>@item.SupplierCode</td>
                            <td>@item.SupplierName</td>
                            <td>@item.ProductCode</td>
                            <td>@item.ProductName</td>
                            <td>@item.InvoiceDateTime</td>
                            <td>@item.PurchaseDate</td>
                            <td class="text-right">@item.Quantity</td>

                            @if (!isSummary)
                            {
                                <td class="text-right">
                                    @(Model.Sum(x => x.UnitPrice).ToString("N2", bd))
                                </td>
                                <td class="text-right">
                                    @(Model.Sum(x => x.SD ?? 0).ToString("N2", bd))
                                </td>
                            }

                            <td class="text-right">
                                @(Model.Sum(x => x.SubTotal).ToString("N2", bd))
                            </td>
                            <td class="text-right">
                                @(Model.Sum(x => x.VATAmount ?? 0).ToString("N2", bd))
                            </td>

                            <td class="text-right">
                                @(Model.Sum(x => x.LineTotal ?? 0).ToString("N2", bd))
                            </td>
                        </tr>
                    }

                    <tr style="font-weight:bold; background:#f1f1f1;">
                        <td colspan="8" style="text-align:left;">Total</td>

                        <td class="text-right">@Model.Sum(x => x.Quantity)</td>

                        @if (!isSummary)
                        {
                            <td></td>
                            <td></td>
                        }

                        <td class="text-right">
                            @(Model.Sum(x => x.SubTotal).ToString("N2", bd))
                        </td>
                        <td class="text-right">
                            @(Model.Sum(x => x.VATAmount ?? 0).ToString("N2", bd))
                        </td>

                        <td class="text-right">
                            @(Model.Sum(x => x.LineTotal ?? 0).ToString("N2", bd))
                        </td>
                    </tr>
                }
                else
                {
                    int totalColumns = isSummary ? 12 : 14;
                    <tr>
                        <td colspan="@totalColumns" style="text-align:center; padding: 20px;">
                            No purchase data found
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

    @*<div style="text-align:right;margin-top:10px;">
            <strong>Total Row:</strong> @(Model != null ? Model.Count : 0)
        </div>*@
</div>
