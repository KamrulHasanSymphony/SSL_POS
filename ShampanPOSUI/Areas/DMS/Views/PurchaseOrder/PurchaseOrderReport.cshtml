
@model ShampanPOS.Models.PurchaseOrderVM

@{
    ViewData["Title"] = "Purchase Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 900px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            font-weight: bold;
        }

    .text-right {
        text-align: right;
    }

    /* 🔥 PRINT LIKE SALES REPORT */
    @@media print {

        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
        }

        .sslPrint {
            display: none !important;
        }
    }

    .purchasetotalrow td {
        border: 0 !important
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    <i class="k-icon k-i-print"></i> Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">@Model.CompanyName</h3>
                <div style="font-size:16px;">@Model.BranchName</div>
                <div>@Model.BranchAddress 69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>

        </tr>
    </table>

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        PURCHASE ORDER 
    </h2>

    <!-- MASTER INFO -->
    <table>
        <tr>
            <th>Order No.</th>
            <td>@Model.Code</td>
            <th>Order Date</th>
            <td style="width:20%!important">@Model.OrderDate</td>
        </tr>
        <tr>
            <th>Supplier</th>
            <td>@Model.SupplierName</td>
            <th>Delivery Date</th>
            <td style="width:20%!important">@Model.DeliveryDateTime</td>
        </tr>
        <tr>
            <th>Supplier Address</th>
            <td colspan="3">@Model.SupplierAddress</td>
        </tr>
    </table>

    <!-- DETAILS -->
    <h3>Purchase Items</h3>
    <table>
        <thead>
            <tr>
                <th style="width:5%!important;" class="text-center">SL</th>
                <th class="text-center">Product</th>
                <th class="text-center">Code</th>
                <th style="width:8%!important;" class="text-center">Qty</th>
                <th style="width:10%!important;" class="text-center">Unit Price</th>
                <th style="width:10%!important;" class="text-center">Sub Total</th>
                <th style="width:10%!important;" class="text-center">SD Amt</th>
                <th style="width:10%!important;" class="text-center">VAT Amt</th>
                <th style="width:10%!important;" class="text-center">Others</th>
                <th style="width:12%!important;" class="text-center">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.purchaseOrderDetailsList)
            {
                <tr>
                    <td>@item.Line</td>
                    <td>@item.ProductName</td>
                    <td>@item.ProductCode</td>
                    <td class="text-right">@item.Quantity</td>
                    <td class="text-right">@item.UnitPrice</td>
                    <td class="text-right">@item.SubTotal</td>
                    <td class="text-right">@item.SDAmount</td>
                    <td class="text-right">@item.VATAmount</td>
                    <td class="text-right">@item.OthersAmount</td>
                    <td class="text-right"><b>@item.LineTotal</b></td>
                </tr>
            }
            <!-- FOOTER ROW: TOTAL ONLY -->

        <tr class="purchasetotalrow" style="font-weight:bold;">
            <td colspan="2" style="text-align: center;">Total :</td> <!-- Product column shows "Total" -->
            <td></td> <!-- Code empty -->
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.Quantity)</td>
            <td></td> <!-- Unit Price empty -->
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.SubTotal)</td>
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.SDAmount)</td>
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.VATAmount)</td>
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.OthersAmount)</td>
            <td class="text-right">@Model.purchaseOrderDetailsList.Sum(x => x.LineTotal)</td>
        </tr>
        </tbody>
    </table>
    <!-- COMMENTS (Label Style, like Sales Order sample) -->
    <div style="margin-top:20px;">
        <h5 class="section-title">Comments</h5>
        <div style="margin-top:5px;">
            @Model.Comments
        </div>
    </div>

</div>



