                        });
                    },
                    error: function (err) {
                        console.error("Error:", err);
                    }
                });
            }

            function loadTop10ProductLastMonthQty(companyId) {
                $.ajax({
                    url: '/Home/GetTop10ProductsCurrentMonthQty',
                    type: 'GET',
                    data: { companyId: companyId, value: 10 },
                    success: function (data) {

                        if (!data || data.length === 0) {
                            console.warn("No data found");
                            return;
                        }

                        // ✅ No filtering / grouping
                        let labels = data.map(x => x.ProductName);
                        let values = data.map(x => Number(x.TotalQuantity));

                        // ✅ Dynamic unique colors for each slice
                        let colors = labels.map((_, i) =>
                            `hsl(${(i * 360 / labels.length)}, 70%, 55%)`
                        );

                        const canvas = document.getElementById('topProductQtyChart');
                        if (!canvas) return;

                        const ctx = canvas.getContext('2d');


                        const now = new Date();
                        const lastMonthDate = new Date(now.getFullYear(), now.getMonth() - 1, 1);

                        const lastMonthName = lastMonthDate.toLocaleString('default', {
                            month: 'long',
                            year: 'numeric'
                        });

                        if (window.topProductQtyChart instanceof Chart) {
                            window.topProductQtyChart.destroy();
                        }

                        window.topProductQtyChart = new Chart(ctx, {
                            type: 'pie',
                            data: {
                                labels: labels,
                                datasets: [{
                                    label: 'Quantity Sold',
                                    data: values,
                                    backgroundColor: colors,
                                    borderColor: '#fff',
                                    borderWidth: 2
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    title: {
                                        display: true,
                                        text: `Top 10 High Selling Products (${lastMonthName})`,
                                        font: { size: 18, weight: 'bold' },
                                        padding: { top: 10, bottom: 20 }
                                    },
                                    legend: {
                                        position: 'bottom'
                                    },
                                    tooltip: {
                                        callbacks: {
                                            label: function (tooltipItem) {
                                                const value = tooltipItem.raw || 0;
                                                const total = values.reduce((a, b) => a + b, 0);
                                                return `${tooltipItem.label}: ${value} (${((value / total) * 100).toFixed(2)}%)`;
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    },
                    error: function (err) {
                        console.error("Error:", err);
                    }
                });
            }

            function loadLowSellingProductLastMonthQty(companyId) {
                $.ajax({
                    url: '/Home/GetLowSellingProductsCurrentMonthQty',
                    type: 'GET',
                    data: { companyId: companyId, value: 10 },  // ✅ pass companyId
                    success: function (data) {

                        if (!data || data.length === 0) {
                            console.warn("No data found");
                            return;
                        }

                        let labels = data.map(x => x.ProductName);
                        let values = data.map(x => Number(x.TotalQuantity));

