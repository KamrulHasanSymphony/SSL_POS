    //                    return response.filter(function (item) {
    //                        return item.Name !== "Customer Wise";
    //                    });

    //                }
    //            }
    //        },

    //        placeholder: "Select Report Type",

    //        dataBound: function () {
    //            if (getReportTypeId && getReportTypeId !== "0") {
    //                this.value(getReportTypeId);
    //            }
    //        },

    //        change: function () {
    //            $("#ReportType").val(this.value());
