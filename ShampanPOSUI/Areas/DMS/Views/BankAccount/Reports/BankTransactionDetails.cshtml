@model List<ShampanPOS.Models.BankTransactionReportVM>

@{
    ViewBag.Title = "Bank Transaction Details Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var totalDeposit = Model.Where(x => x.TransactionType == "Deposit").Sum(x => x.Amount);
    var totalWithdrawal = Model.Where(x => x.TransactionType == "Withdrawal").Sum(x => x.Amount);
    var grandTotal = totalDeposit - totalWithdrawal;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1200px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
        cursor: pointer;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    /* Row Colors */
    .row-deposit {
        background-color: #d4edda;
    }

    .row-withdrawal {
        background-color: #f8d7da;
    }

    /* Footer Total Rows */
    .total-deposit {
        background-color: #c3e6cb;
        color: #155724;
        font-weight: bold;
    }

    .total-withdrawal {
        background-color: #f5c6cb;
        color: #721c24;
        font-weight: bold;
    }

    .total-grand {
        background-color: #2c3e50;
        color: #fff;
        font-weight: bold;
    }

    /* Legend */
    .legend {
        margin-bottom: 8px;
        font-size: 12px;
    }

    .legend-box {
        display: inline-block;
        width: 14px;
        height: 14px;
        margin-right: 4px;
        vertical-align: middle;
        border: 1px solid #999;
    }

    .legend-deposit {
        background-color: #d4edda;
    }

    .legend-withdrawal {
        background-color: #f8d7da;
    }

    /* Table Responsive */
    .table-responsive {
        overflow-x: auto;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 1200px;
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
            overflow: visible;
        }

        .sslPrint {
            display: none !important;
        }

        .table-responsive {
            overflow: visible !important;
        }
    }
</style>

<button onclick="window.print()" class="sslPrint">Print</button>

<div class="report-box">

    <!-- ================= HEADER ================= -->
    <table style="border:none; margin-bottom:10px;">
        <tr>
            <td style="width:140px; border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px; height:120px;" />
            </td>
            <td style="text-align:right; border:none;">
                <h3 style="margin:0;">@ViewBag.CompanyName</h3>
                <div>@ViewBag.BranchName</div>
                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gmail.com</div>
            </td>
        </tr>
    </table>

    <hr />

    <!-- ================= FILTER INFO ================= -->
    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
        <div>
            <strong>Bank:</strong> @ViewBag.BankName <br />
            <strong>Account:</strong> @ViewBag.AccountName <br />
            <strong>Transaction Type:</strong> @ViewBag.TransactionType <br />
            <strong>Deposit Code:</strong> @(ViewBag.DepositCode == "All" || string.IsNullOrEmpty(ViewBag.DepositCode as string) ? "All" : ViewBag.DepositCode)
        </div>
        <div style="text-align:right;">
            <strong>From Date:</strong> @ViewBag.FromDate <br />
            <strong>To Date:</strong> @ViewBag.ToDate <br />
            <strong>Withdrawal Code:</strong> @(ViewBag.WithdrawalCode == "All" || string.IsNullOrEmpty(ViewBag.WithdrawalCode as string) ? "All" : ViewBag.WithdrawalCode) <br />
            <strong>Printed On:</strong> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </div>
    </div>

    <!-- ================= TITLE ================= -->
    <h3 style="text-align:center; border-bottom:1px solid #000; padding-bottom:6px;">
        @(ViewBag.TransactionType == "Deposit" ? "BANK DEPOSIT REPORT" :
  ViewBag.TransactionType == "Withdrawal" ? "BANK WITHDRAWAL REPORT" :
  "BANK TRANSACTION REPORT") (DETAILS)
    </h3>

    <!-- ================= LEGEND ================= -->
    @if (string.IsNullOrEmpty(ViewBag.TransactionType as string) || ViewBag.TransactionType == "All")
    {
        <div class="legend">
            <span class="legend-box legend-deposit"></span> Deposit &nbsp;&nbsp;
            <span class="legend-box legend-withdrawal"></span> Withdrawal
        </div>
    }

    @using System.Globalization
    @{ var bd = new CultureInfo("en-IN"); }

    <!-- ================= TABLE ================= -->
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Type</th>
                    <th>Transaction Code</th>
                    <th>Transaction Date</th>
                    <th>Bank Name</th>
                    <th>Account No</th>
                    <th>Account Name</th>
                    <th>Reference</th>
                    <th>Cheque No</th>
                    <th>Cheque Bank</th>
                    <th>Cheque Date</th>
                    <th>Is Cash</th>
                    <th>Comments</th>
                    <th>Amount</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    int serial = 1;

                    foreach (var item in Model.Where(x =>
                    ViewBag.TransactionType == "Deposit" ? x.TransactionType == "Deposit" :
                    ViewBag.TransactionType == "Withdrawal" ? x.TransactionType == "Withdrawal" : true))
                    {
                        string rowClass = item.TransactionType == "Deposit"
                            ? "row-deposit"
                            : "row-withdrawal";

                        <tr class="@rowClass">
                            <td class="text-center">@serial</td>
                            <td>@item.TransactionType</td>
                            <td>@item.TransactionCode</td>
                            <td>@(item.TransactionDate)</td>
                            <td>@item.BankName</td>
                            <td>@item.AccountNo</td>
                            <td>@item.AccountName</td>
                            <td>@item.Reference</td>
                            <td>@item.ChequeNo</td>
                            <td>@item.ChequeBankName</td>
                            <td>@item.ChequeDate</td>
                            <td class="text-center">@(item.IsCash ? "Yes" : "No")</td>
                            <td>@item.Comments</td>
                            <td class="text-right">@item.Amount.ToString("N2", bd)</td>
                        </tr>

                        serial++;
                    }

                    <!-- ================= TOTAL ROWS ================= -->
                    if (ViewBag.TransactionType == "Deposit")
                    {
                        <tr class="total-deposit">
                            <td colspan="13" class="text-right">Total Deposit:</td>
                            <td class="text-right">@totalDeposit.ToString("N2", bd)</td>
                        </tr>
                    }
                    else if (ViewBag.TransactionType == "Withdrawal")
                    {
                        <tr class="total-withdrawal">
                            <td colspan="13" class="text-right">Total Withdrawal:</td>
                            <td class="text-right">@totalWithdrawal.ToString("N2", bd)</td>
                        </tr>
                    }
                    else
                    {
                        <tr class="total-deposit">
                            <td colspan="13" class="text-right">Total Deposit:</td>
                            <td class="text-right">@totalDeposit.ToString("N2", bd)</td>
                        </tr>
                        <tr class="total-withdrawal">
                            <td colspan="13" class="text-right">Total Withdrawal:</td>
                            <td class="text-right">@totalWithdrawal.ToString("N2", bd)</td>
                        </tr>
                        <tr class="total-grand">
                            <td colspan="13" class="text-right">Net Balance (Deposit - Withdrawal):</td>
                            <td class="text-right">@grandTotal.ToString("N2", bd)</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="14" class="text-center">No data found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ================= RECORD COUNT ================= -->
    <div style="text-align:right; margin-top:5px;">
        <strong>Total Records:</strong> @(Model != null ? Model.Count : 0)
    </div>

</div>