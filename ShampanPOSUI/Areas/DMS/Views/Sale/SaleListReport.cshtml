@model List<ShampanPOS.Models.SaleReportVM>

@{
    ViewBag.Title = "Sale Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;

    // 🔥 FIX: int → string (API এর সাথে match করার জন্য)
    string reportType = ViewBag.ReportType != null ? ViewBag.ReportType.ToString() : "";
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">Print</button>

<div class="report-box">

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        SALE REPORT (@(isSummary ? "SUMMARY" : "DETAILS"))
    </h2>

    <table>
        <thead>
            <tr>

                @if (isSummary)
                {
                    if (reportType == "Day Wise")
                    {
                        <th>Date</th>
                        <th>Total Invoice</th>
                        <th>Quantity</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Monthly")
                    {
                        <th>Month</th>
                        <th>Total Invoice</th>
                        <th>Quantity</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Customer Wise")
                    {
                        <th>Customer</th>
                        <th>Total Invoice</th>
                        <th>Quantity</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Product Wise")
                    {
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Invoice Wise")
                    {
                        <th>Sale Code</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Quantity</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                }
                else
                {
                    if (reportType == "Day Wise")
                    {
                        <th>Date</th>
                        <th>Sale Code</th>
                        <th>Quantity</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Monthly")
                    {
                        <th>Month</th>
                        <th>Sale Code</th>
                        <th>Date</th>
                        <th>Quantity</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Customer Wise")
                    {
                        <th>Customer</th>
                        <th>Sale Code</th>
                        <th>Date</th>
                        <th>Quantity</th>
                        <th>Unit Rate</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Product Wise")
                    {
                        <th>Product</th>
                        <th>Sale Code</th>
                        <th>Date</th>
                        <th>Quantity</th>
                        <th>Unit Rate</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                    else if (reportType == "Invoice Wise")
                    {
                        <th>Sale Code</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Unit Rate</th>
                        <th>Sub Total</th>
                        <th>VAT</th>
                        <th>Total</th>
                    }
                }

            </tr>
        </thead>

        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        @if (isSummary)
                        {
                            if (reportType == "Day Wise")
                            {
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.TotalInvoice</td>
                                <td>@item.Quantity</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Monthly")
                            {
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.TotalInvoice</td>
                                <td>@item.Quantity</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Customer Wise")
                            {
                                <td>@item.CustomerName</td>
                                <td>@item.TotalInvoice</td>
                                <td>@item.Quantity</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Product Wise")
                            {
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Invoice Wise")
                            {
                                <td>@item.Code</td>
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.CustomerName</td>
                                <td>@item.Quantity</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                        }
                        else
                        {
                            if (reportType == "Day Wise")
                            {
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.Code</td>
                                <td>@item.Quantity</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Monthly")
                            {
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.Code</td>
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.Quantity</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Customer Wise")
                            {
                                <td>@item.CustomerName</td>
                                <td>@item.Code</td>
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitRate</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Product Wise")
                            {
                                <td>@item.ProductName</td>
                                <td>@item.Code</td>
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitRate</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                            else if (reportType == "Invoice Wise")
                            {
                                <td>@item.Code</td>
                                <td>@item.InvoiceDateTime</td>
                                <td>@item.CustomerName</td>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitRate</td>
                                <td>@item.SubTotal</td>
                                <td>@item.VATAmount</td>
                                <td>@item.LineTotal</td>
                            }
                        }
                    </tr>
                }

                <!-- TOTAL -->


                <tr style="font-weight:bold;background:#f1f1f1;">
                    @if (isSummary)
                    {
                        if (reportType == "Day Wise")
                        {
                            <td>Total</td>
                            <td class="text-right">@Model.Sum(x => x.TotalInvoice)</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Monthly")
                        {
                            <td>Total</td>
                            //<td></td>
                            <td class="text-right">@Model.Sum(x => x.TotalInvoice)</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Customer Wise")
                        {
                            <td>Total</td>
                            //<td></td>
                            <td class="text-right">@Model.Sum(x => x.TotalInvoice)</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Product Wise")
                        {
                            <td>Total</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Invoice Wise")
                        {
                            <td>Total</td>
                            <td></td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else
                        {
                            <td>Total</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                    }
                    else
                    {
                        if (reportType == "Day Wise")
                        {
                            <td>Total</td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Monthly")
                        {
                            <td>Total</td>
                            <td></td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Customer Wise")
                        {
                            <td>Total</td>
                            <td></td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.UnitRate)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Product Wise")
                        {
                            <td>Total</td>
                            <td></td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.UnitRate)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else if (reportType == "Invoice Wise")
                        {
                            <td>Total</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.UnitRate)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                        else
                        {
                            <td>Total</td>
                            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                            <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                            <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                            <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                        }
                    }
                </tr>

            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;">No data</td>
                </tr>
            }

        </tbody>
    </table>

</div>