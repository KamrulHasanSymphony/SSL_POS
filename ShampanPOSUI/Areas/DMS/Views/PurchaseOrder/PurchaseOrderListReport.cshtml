@model List<ShampanPOS.Models.PurchaseOrderReportVM>

@{
    ViewBag.Title = "Purchase Order Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;margin-bottom:10px;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">Symphony Softtech Limited</h3>
                <div>69/1 Tridhara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gmail.com</div>
            </td>
        </tr>
    </table>

    <!-- TITLE -->
    <h2 style="text-align:center;border-bottom:1px solid #000;">
        PURCHASE ORDER REPORT (@(isSummary ? "SUMMARY" : "DETAILS"))
    </h2>

    <!-- TABLE -->
    <table>
        <thead>
            <tr>
                <th>Purchase Order Code</th>
                <th>Supplier</th>
                <th>Order Date</th>
                <th>Delivery Date </th>
                <th>Product</th>

                @if (!isSummary)
                {
                    //<th>Product</th>
                    //<th>Product Code</th>
                }

                <th>Quantity</th>
                <th>Sub Total</th>
                <th>VAT Amount</th>
                <th>Line Total</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.SupplierName</td>
                        <td>@item.OrderDate</td>
                        <td>@item.DeliveryDateTime</td>
                        <td>@item.ProductName</td>


                        @if (!isSummary)
                        {
                            //<td>@item.ProductName</td>
                            //<td>@item.ProductCode</td>
                        }

                        <td class="text-right">@item.Quantity</td>
                        <td class="text-right">@item.SubTotal</td>
                        <td class="text-right">@item.VATAmount</td>
                        <td class="text-right">@item.LineTotal</td>
                    </tr>
                }

                <!-- TOTAL -->
                <tr style="font-weight:bold;background:#f1f1f1;">
                    <td colspan="@(isSummary ? 4 : 5)">Total</td>

                    <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                    <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                    <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                    <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;">
                        No purchase order data found
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- FOOTER -->
    <div style="text-align:right;margin-top:10px;">
        <strong>Total Rows:</strong> @(Model != null ? Model.Count : 0)
    </div>

</div>