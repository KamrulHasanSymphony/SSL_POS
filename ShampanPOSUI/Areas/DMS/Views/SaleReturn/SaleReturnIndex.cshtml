    function GetReportTypeComboBox() {

        $("#ReportType").kendoMultiColumnComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            height: 400,

            columns: [
                { field: "Name", title: "Report Type", width: 200 }
            ],

            filter: "contains",
            filterFields: ["Name"],

            dataSource: {
                transport: {
                    read: {
                        url: "/Common/Common/GetReportTypeList",
                        dataType: "json",
                        data: function () {
                            return {
                                Value: "SaleReturnReportType"   // ✅ IMPORTANT FIX
                            };
                        }
                    }
                }
            },

            placeholder: "Select Report Type",
            value: "",

            dataBound: function () {

                if (typeof getReportTypeId !== "undefined" &&
                    getReportTypeId &&
                    getReportTypeId !== "0") {

                    this.value(getReportTypeId);
                }
                else {
                    this.value("");
                }
            },

            change: function () {

                var selected = this.dataItem();

                // ✅ store proper value
                if (selected) {
                    $("#ReportType").val(selected.Name);
                }
            }
        });
    }

    $(document).ready(function () {
        // Initialize Kendo DatePicker for FromDate and ToDate fields
        $("#FromDate").kendoDatePicker();
        $("#ToDate").kendoDatePicker();

        // Get the current date
        var currentDate = new Date();

        // Set the current date for both FromDate and ToDate fields
        $("#FromDate").data("kendoDatePicker").value(currentDate);
        $("#ToDate").data("kendoDatePicker").value(currentDate);

        GetCustomerComboBox();
        GetReportTypeComboBox();

        $("input[data-bootstrap-switch]").bootstrapSwitch();

        // 🔥 APPLY DEFAULT FILTER HERE
        var isSummary = $("#IsSummary").is(":checked");
        //applyReportTypeFilter(isSummary);
    });



</script>

