@model ShampanPOS.Models.ProductVM
@{
    ViewBag.Title = "Product Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 900px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 20px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            font-weight: bold;
        }

    .text-right {
        text-align: right;
    }

    /* 🔥 PRINT LIKE SALES REPORT */
    @@media print {

        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
        }

        .sslPrint {
            display: none !important;
        }
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <div style="font-size:16px;">@Model.CompanyName</div>
                <div style="font-size:13px;">@Model.BranchName</div>
                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>

        </tr>
    </table>

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        PRODUCT REPORT
    </h2>

    <!-- PRODUCT INFO -->
    <table>
        <tr>
            <th>Name</th>
            <td>@Model.Name</td>
            <th>Product No.</th>
            <td style="width: 20%!important">@Model.Code</tdstyle="width:>
        </tr>
        <tr>
            <th>Bangla Name</th>
            <td>@Model.BanglaName</td>
            <th>Group</th>
            <td style="width: 20%!important">@Model.ProductGroupName</td>
        </tr>
        <tr>
            <th>HS No.</th>
            <td>@Model.HSCodeNo</td>
            <th>UOM</th>
            <td style="width: 20%!important">@Model.UOMName</td>
        </tr>
    </table>

    <!-- PRICING -->
    <h3>Pricing Information</h3>
    <table>
        <tr>
            <th>Sale Price</th>
            <td>@Model.SalePrice</td>
            <th>VAT Rate (%)</th>
            <td style="width: 20%!important">@Model.VATRate</td>
        </tr>
        <tr>
            <th>Purchase Price</th>
            <td>@Model.PurchasePrice</td>
            <th>SD Rate (%)</th>
            <td style="width: 20%!important">@Model.SDRate</td>
        </tr>
    </table>

    <!-- COMMENTS -->
    <!--<div style="margin-top:20px;">
        <h5>Comments</h5>
        <div style="margin-top:5px;">
            Product information report.
        </div>
    </div>-->

</div>