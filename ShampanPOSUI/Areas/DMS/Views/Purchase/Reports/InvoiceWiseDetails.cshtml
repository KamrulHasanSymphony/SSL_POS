@model List<ShampanPOS.Models.PurchaseReportVM>

@{
    ViewBag.Title = "Invoice Wise Details Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
    }
</style>

<button onclick="window.print()" class="sslPrint">Print</button>

<div class="report-box">

    <!-- ================= HEADER ================= -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>

            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">
                    @ViewBag.CompanyName
                </h3>

                <div>
                    @ViewBag.BranchName
                </div>

                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>
        </tr>
    </table>

    <hr />

    <!-- ================= FILTER INFO ================= -->
    <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
        <div>
            <strong>Supplier:</strong> @ViewBag.SupplierName <br />
            <strong>From:</strong> @ViewBag.InvoiceFromDate
        </div>

        <div style="text-align:right;">
            <strong>Product:</strong> @ViewBag.ProductName <br />
            <strong>To:</strong> @ViewBag.InvoiceToDate
        </div>
    </div>

    <h3 style="text-align:center;border-bottom:1px solid #000;">
        Invoice Wise Details Report
    </h3>

    <!-- ================= TABLE ================= -->
    <table>
        <thead>
            <tr>
                <th>Purchase Code</th>
                <th>Invoice Date</th>
                <th>Purchase Date</th>
                <th>Supplier</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Rate</th>
                <th>VAT</th>
                <th>Total</th>
            </tr>
        </thead>

        @using System.Globalization
        @{
            var bd = new CultureInfo("en-IN");
        }
        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.InvoiceDateTime</td>
                        <td>@item.PurchaseDate</td>
                        <td>@item.SupplierName</td>
                        <td>@item.ProductName</td>
                        <td class="text-right">@item.Quantity</td>
                        <td class="text-right">@item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("en-IN"))</td>
                        <td class="text-right"> @((item.VATAmount ?? 0).ToString("N2", bd))</td>
                        <td class="text-right"><b>@((item.LineTotal ?? 0).ToString("N2", bd))</b></td>
                    </tr>
                }

                <!-- ================= TOTAL ================= -->
        <tr style="font-weight:bold;background:#f1f1f1;">
            <td>Total</td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td class="text-right">@Model.Sum(x => x.Quantity)</td>
            <td class="text-right">@(Model.Sum(x => x.UnitPrice).ToString("N2", bd))</td>
            <td class="text-right">@(Model.Sum(x => x.VATAmount ?? 0).ToString("N2", bd))</td>
            <td class="text-right">@(Model.Sum(x => x.LineTotal ?? 0).ToString("N2", bd))</td>
        </tr>
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center;">
                        No data found
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>