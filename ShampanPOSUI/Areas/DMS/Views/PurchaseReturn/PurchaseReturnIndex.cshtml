    function GetReportTypeComboBox() {

        $("#ReportType").kendoMultiColumnComboBox({
            dataTextField: "Name",
            dataValueField: "Id",
            height: 400,

            columns: [
                { field: "Name", title: "Report Type", width: 200 }
            ],

            filter: "contains",
            filterFields: ["Name"],

            dataSource: {
                transport: {
                    read: {
                        url: "/Common/Common/GetReportTypeList",
                        dataType: "json",
                        data: function () {
                            return {
                                Value: "PurchaseReturnReportType"   // ✅ IMPORTANT FIX
                            };
                        }
                    }
                }
            },

            placeholder: "Select Report Type",
            value: "",

            dataBound: function () {

                if (typeof getReportTypeId !== "undefined" &&
                    getReportTypeId &&
                    getReportTypeId !== "0") {

                    this.value(getReportTypeId);
                }
                else {
                    this.value("");
                }
            },

            change: function () {

                var selected = this.dataItem();

                // ✅ store proper value
                if (selected) {
                    $("#ReportType").val(selected.Name);
                }
            }
        });
    }




    function PrintPurchaseReport() {

        var supplierId = $("#SupplierId").data("kendoMultiColumnComboBox").value();
        var reportType = $("#ReportType").data("kendoMultiColumnComboBox").value();
        var combo = $("#SupplierId").data("kendoMultiColumnComboBox");
        var supplierName = combo ? combo.text() : "";
        var isSummary = $("#IsSummary").is(":checked");


        supplierId = supplierId || 0;
        reportType = reportType || 0;

        var fromDate = "";
        var toDate = "";
        var invoiceFromDate = "";
        var invoiceToDate = "";

        if ($("#chkPurchaseFromDate").is(":checked")) {
            fromDate = $("#PurchaseFromDate").val();
        }

        if ($("#chkPurchaseToDate").is(":checked")) {
            toDate = $("#PurchaseToDate").val();
        }

        if ($("#chkInvoiceFromDate").is(":checked")) {
            invoiceFromDate = $("#InvoiceFromDate").val();
        }

        if ($("#chkInvoiceToDate").is(":checked")) {
            invoiceToDate = $("#InvoiceToDate").val();
        }

      var url = '@Url.Action("PurchaseReturnListReport", "PurchaseReturn", new { area = "DMS" })'
    + '?supplierId=' + supplierId
    + '&fromDate=' + fromDate
    + '&toDate=' + toDate
    + '&invoiceFromDate=' + invoiceFromDate
    + '&invoiceToDate=' + invoiceToDate
    + '&reportType=' + reportType
    + '&isSummary=' + isSummary;

        window.open(url, "_blank");
    }


    $("#chkPurchaseFromDate").change(function () {
        $("#PurchaseFromDate").prop("disabled", !this.checked);
    });

    $("#chkPurchaseToDate").change(function () {
        $("#PurchaseToDate").prop("disabled", !this.checked);
    });

    $("#chkInvoiceFromDate").change(function () {
        $("#InvoiceFromDate").prop("disabled", !this.checked);
    });

    $("#chkInvoiceToDate").change(function () {
        $("#InvoiceToDate").prop("disabled", !this.checked);
    });





</script>

