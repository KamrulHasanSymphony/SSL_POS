@model ShampanPOS.Models.LoginResource
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<style>

    .input-group-wrapper {
        position: relative;
        margin-bottom: 25px;
    }

    .validation-msg {
        position: absolute;
        left: 0;
        top: 100%;
        font-size: 14px;
        margin-top: 2px;
        color: red;
    }
    .footer-logo {
        margin-top: 8px; 
        text-align: center;
    }

        .footer-logo img {
            height: 52px; 
            display: inline-block;
        }
</style>

<!DOCTYPE html>
<html lang="en">

<body class="hold-transition login-page">
    <div class="login-box">
        <div class="card">
            <div class="card-header text-center">
                <a href="https://www.symphonysofttech.com/" target="_blank">
                    <img src="~/Content/AdminLte/dist/img/osaka-logo.jpg" alt="Company Logo" class="logo">
                </a>
            </div>

            <h5 style="font-weight:800;font-size:18px;padding-top:7px;"> POINT OF SALES  </h5>

            <div class="card-body login-card-body">

                @using (Html.BeginForm("Index", "Login", FormMethod.Post))
                {
                    @Html.ValidationSummary(true)

                    @Html.HiddenFor(model => model.returnUrl)
                    @Html.HiddenFor(model => model.dbName)

                    @*<div class="input-group mb-3">
                @Html.TextBoxFor(model => model.UserName, new { @class = "form-control", @placeholder = "User Name" })
                <div class="input-group-append">
                    <span class="input-group-text"><i class="fa fa-user"></i></span>
                </div>
            </div>
            @Html.ValidationMessageFor(model => model.UserName)

            <div class="input-group mb-3">
                @Html.TextBoxFor(model => model.Password, new { @class = "form-control", type = "password", @placeholder = "Password" })
                <div class="input-group-append">
                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                </div>
            </div>
            @Html.ValidationMessageFor(model => model.Password)*@








            




                    <div class="input-group-wrapper">
                <div class="input-group mb-1">
                    @Html.TextBoxFor(model => model.UserName,
                        new { @class = "form-control", @placeholder = "User Name" })

                    <div class="input-group-append">
                        <span class="input-group-text">
                            <i class="fa fa-user"></i>
                        </span>
                    </div>
                </div>

                @Html.ValidationMessageFor(model => model.UserName, "",
                    new { @class = "text-danger validation-msg" })
            </div>


                    <div class="input-group-wrapper">
                        <div class="input-group mb-1">
                            @Html.TextBoxFor(model => model.Password,
                                new
                                     {
                                    @class = "form-control",
                                    type = "password",
                                    @placeholder = "Password"
                                })

                            <div class="input-group-append">
                                <span class="input-group-text">
                                    <i class="fas fa-key"></i>
                                </span>
                            </div>
                        </div>

                        @Html.ValidationMessageFor(model => model.Password, "",
                            new { @class = "text-danger validation-msg" })
                    </div>



                    <div class="input-group mb-3">
                        <select id="CompanyId" name="CompanyId" class="form-control">
                            @foreach (var item in Model.CompanyInfos)
                            {
                                <option value="@item.CompanyId">@item.CompanyName</option>
                            }
                        </select>
                        <div class="input-group-append">
                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                        </div>
                    </div>

                    @*@Html.ValidationMessageFor(model => model.Message)*@


                    <div class="text-center">
                        @if (!string.IsNullOrEmpty(Model.Message))
                        {
                            <div class="alert alert-danger">
                                @Model.Message
                            </div>
                        }
                    </div>

                    <div class="clearfix"></div>

                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary btn-block">Log In</button>
                        </div>
                    </div>



                    @*<div class="row mt-2 justify-content-center">
                <div class="col-6 text-center">
                    <a href="@Url.Action("SignUpCreate", "SignUp", new { area = "SetUp" })" style="text-decoration: underline; color: blue; cursor: pointer;">
                        Create an Account
                    </a>
                </div>
            </div>*@

                    <div class="row mt-2 justify-content-center">
                        <div class="col-6 text-center">
                            <a href="@Url.Action("RegistrationCreate", "Registration", new { area = "SetUp" })" style="text-decoration: underline; color: blue; cursor: pointer;">
                                Create an Account
                            </a>
                        </div>
                    </div>



                    @*<button type="button" title="Sign Up" data-url="/SetUp/UserProfile/Create" onclick="GoTo(this)" class="button NewButton addNewButton">
                New
            </button>*@
                }
            </div>
        </div>

        <div class="row footer-logo">
            <div class="col-md-12 text-center">
                <a href="https://www.symphonysofttech.com/" target="_blank">
                    <img src="~/Content/AdminLte/dist/img/logo.png"
                         alt="Symphony Logo">
                </a>
            </div>
        </div>


        @*<div class="row" style="text-align:left !important;">
            <div class="col-md-2">
                <a href="https://www.symphonysofttech.com/" target="_blank">
                    <img src="~/Content/AdminLte/dist/img/logo.png" alt="Symphony Logo" class="logo" height="30">
                </a>
            </div>
        </div>*@

    </div>

</body>


</html>

<link href="~/Content/bootstrap.min.css" rel="stylesheet" />
<script src="~/Scripts/bootstrap.min.js"></script>
<script src="~/Scripts/jquery-3.7.0.min.js"></script>

<script>

    $(document).ready(function () {
        $(".fa-key").on("click", function () {
             
            let passwordInput = $("#Password");
            let type = passwordInput.attr("type") === "password" ? "text" : "password";
            passwordInput.attr("type", type);
            // Toggle icon class
            $(this).toggleClass("fa-eye fa-eye-slash");
        });
    });

</script>


