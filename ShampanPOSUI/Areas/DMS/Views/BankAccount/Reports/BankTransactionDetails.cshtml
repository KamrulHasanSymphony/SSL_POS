@model List<ShampanPOS.Models.BankTransactionReportVM>

@{
    ViewBag.Title = "Bank Transaction Details Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var totalDeposit = Model.Where(x => x.TransactionType == "Deposit").Sum(x => x.Amount);
    var totalWithdrawal = Model.Where(x => x.TransactionType == "Withdrawal").Sum(x => x.Amount);
    var grandTotal = totalDeposit - totalWithdrawal;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1200px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #555;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
        cursor: pointer;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #555;
            padding: 6px;
        }

        table th {
            background: #d0d0d0;
            color: #000;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    /* Row Colors - B&W */
    .row-deposit {
        background-color: #f5f5f5;
    }

    .row-withdrawal {
        background-color: #e0e0e0;
    }

    /* Footer Total Rows - B&W */
    .total-deposit {
        background-color: #d8d8d8;
        color: #000;
        font-weight: bold;
    }

    .total-withdrawal {
        background-color: #c0c0c0;
        color: #000;
        font-weight: bold;
    }

    .total-grand {
        background-color: #333;
        color: #fff;
        font-weight: bold;
    }

    /* Legend */
    .legend {
        margin-bottom: 8px;
        font-size: 12px;
    }

    .legend-box {
        display: inline-block;
        width: 14px;
        height: 14px;
        margin-right: 4px;
        vertical-align: middle;
        border: 1px solid #555;
    }

    .legend-deposit {
        background-color: #f5f5f5;
    }

    .legend-withdrawal {
        background-color: #e0e0e0;
    }

    /* Table Responsive */
    .table-responsive {
        overflow-x: auto;
    }

    /* Report Footer (below table) */
    .report-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-top: 10px;
        font-size: 13px;
    }

        .report-footer .footer-left {
            text-align: left;
        }

        .report-footer .footer-right {
            text-align: right;
        }

    /* ===================== PRINT STYLES ===================== */
    @@media print {
    body * {
        visibility: hidden;
    }
    .report-box,
    .report-box * {
        visibility: visible;
    }
    .sslPrint {
        display: none !important;
    }
    .report-box {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 10px;
        background: #fff;
        border: none;
        overflow: visible;
    }

    /* পেজ সেটিংস এবং পেজ নাম্বার কাউন্টার */
    @@page {
        size: A4 landscape;
        margin: 15mm 10mm 15mm 10mm; /* Top, Right, Bottom, Left */
    }

    /* ব্রাউজারে পেজ নাম্বার দেখানোর জন্য (Chrome/Edge/Firefox সাপোর্ট করবে) */
    .page-number::after {
        content: "Page " counter(page);
    }

    table {
        /*font-size: 10px;*/
        width: 100%;
        table-layout: fixed;
        word-break: break-word;
        border-collapse: collapse; /* বর্ডার সুন্দর দেখানোর জন্য */
    }

    /* এই কোডটি নিশ্চিত করবে যেন প্রতি পেজে টেবিলের হেডার রিপিট হয় */
    thead {
        display: table-header-group;
    }
    tr {
        page-break-inside: avoid; /* যেন একটা রো মাঝখান দিয়ে কেটে দুই পেজে চলে না যায় */
    }

    table th, table td {
        padding: 3px 4px;
        font-size: 10px;
    }

    .table-responsive {
        overflow: visible !important;
        width: 100%;
    }

    /* ফুটারটি একদম পেজের নিচে ফিক্সড থাকবে */
    .report-footer {
        display: flex !important;
        justify-content: space-between;
        position: running(footer);
    }
}
</style>

<button onclick="window.print()" class="sslPrint">🖨️ Print</button>

<div class="report-box">
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <td colspan="14" style="border:none; padding:0;">
                        <table style="border:none; margin-bottom:10px; width:100%;">
                            <tr>
                                <td style="width:140px; border:none;">
                                    <img src="~/Content/AdminLte/dist/img/logo.png" style="width:230px; height:120px;" />
                                </td>
                                <td style="text-align:right; border:none;">
                                    <h3 style="margin:0;">@ViewBag.CompanyName</h3>
                                    <div>@ViewBag.BranchName</div>
                                    <div>69/1 Trhidara Tower</div>
                                    <div>📞 01612264439</div>
                                    <div>✉️ symphonysorftech1999@gmail.com</div>
                                </td>
                            </tr>
                        </table>
                        <hr />
                    </td>
                </tr>

                <tr>
                    <td colspan="14" style="border:none; padding:0;">
                        <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size: 11px;">
                            <div>
                                <strong>Bank:</strong> @ViewBag.BankName <br />
                                <strong>Account:</strong> @ViewBag.AccountName <br />
                                <strong>Transaction Type:</strong> @ViewBag.TransactionType <br />
                                <strong>Deposit Code:</strong> @(ViewBag.DepositCode == "All" || string.IsNullOrEmpty(ViewBag.DepositCode as string) ? "All" : ViewBag.DepositCode)
                            </div>
                            <div style="text-align:right;">
                                <strong>From Date:</strong> @ViewBag.FromDate <br />
                                <strong>To Date:</strong> @ViewBag.ToDate <br />
                                <strong>Withdrawal Code:</strong> @(ViewBag.WithdrawalCode == "All" || string.IsNullOrEmpty(ViewBag.WithdrawalCode as string) ? "All" : ViewBag.WithdrawalCode) <br />
                            </div>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td colspan="14" style="border:none; padding:0;">
                        <h3 style="text-align:center; border-bottom:1px solid #000; padding-bottom:6px; margin-top:0;">
                            @(ViewBag.TransactionType == "Deposit" ? "BANK DEPOSIT REPORT" :
                              ViewBag.TransactionType == "Withdrawal" ? "BANK WITHDRAWAL REPORT" :
                              "BANK TRANSACTION REPORT") (DETAILS)
                        </h3>

                        @if (string.IsNullOrEmpty(ViewBag.TransactionType as string) || ViewBag.TransactionType == "All")
                        {
                        <div class="legend" style="margin-bottom: 10px;">
                            <span class="legend-box legend-deposit"></span> Deposit &nbsp;&nbsp;
                            <span class="legend-box legend-withdrawal"></span> Withdrawal
                        </div>
                        }
                    </td>
                </tr>

                <tr>
                    <th>SL</th>
                    <th>Type</th>
                    <th>Transaction Code</th>
                    <th>Transaction Date</th>
                    <th>Bank Name</th>
                    <th>Account No</th>
                    <th>Account Name</th>
                    <th>Reference</th>
                    <th>Cheque No</th>
                    <th>Cheque Bank</th>
                    <th>ChequeEntry Date</th>
                    <th>Is Cash</th>
                    <th>Comments</th>
                    <th>Amount</th>
                </tr>
            </thead>

            @using System.Globalization
            @{ var bd = new CultureInfo("en-IN"); }

            <tbody>
                @if (Model != null && Model.Any())
                {
                    int serial = 1;

                    foreach (var item in Model.Where(x =>
                        ViewBag.TransactionType == "Deposit" ? x.TransactionType == "Deposit" :
                        ViewBag.TransactionType == "Withdrawal" ? x.TransactionType == "Withdrawal" : true))
                    {
                        string rowClass = item.TransactionType == "Deposit" ? "row-deposit" : "row-withdrawal";

                <tr class="@rowClass">
                    <td class="text-center">@serial</td>
                    <td>@item.TransactionType</td>
                    <td>@item.TransactionCode</td>
                    <td>@(item.TransactionDate)</td>
                    <td>@item.BankName</td>
                    <td>@item.AccountNo</td>
                    <td>@item.AccountName</td>
                    <td>@item.Reference</td>
                    <td>@item.ChequeNo</td>
                    <td>@item.ChequeBankName</td>
                    <td>@item.ChequeDate</td>
                    <td class="text-center">@(item.IsCash ? "Yes" : "No")</td>
                    <td>@item.Comments</td>
                    <td class="text-right">@item.Amount.ToString("N2", bd)</td>
                </tr>
                        serial++;
                    }

                    if (ViewBag.TransactionType == "Deposit")
                    {
                <tr class="total-deposit">
                    <td colspan="13" class="text-right">Total Deposit:</td>
                    <td class="text-right">@totalDeposit.ToString("N2", bd)</td>
                </tr>
                    }
                    else if (ViewBag.TransactionType == "Withdrawal")
                    {
                <tr class="total-withdrawal">
                    <td colspan="13" class="text-right">Total Withdrawal:</td>
                    <td class="text-right">@totalWithdrawal.ToString("N2", bd)</td>
                </tr>
                    }
                    else
                    {
                <tr class="total-deposit">
                    <td colspan="13" class="text-right">Total Deposit:</td>
                    <td class="text-right">@totalDeposit.ToString("N2", bd)</td>
                </tr>
                <tr class="total-withdrawal">
                    <td colspan="13" class="text-right">Total Withdrawal:</td>
                    <td class="text-right">@totalWithdrawal.ToString("N2", bd)</td>
                </tr>
                <tr class="total-grand">
                    <td colspan="13" class="text-right">Net Balance (Deposit - Withdrawal):</td>
                    <td class="text-right">@grandTotal.ToString("N2", bd)</td>
                </tr>
                    }
                }
                else
                {
                <tr>
                    <td colspan="14" class="text-center">No data found</td>
                </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="report-footer" style="margin-top: 15px; border-top: 1px solid #ccc; padding-top: 5px;">
        <div class="footer-left">
            <strong>Printed By:</strong> @(ViewBag.PrintedBy ?? "N/A") |
            <strong>Printed On:</strong> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </div>
        <div class="footer-right">
            <span class="page-number"></span> |
            <strong>Total Records:</strong> @(Model != null ? Model.Count : 0)
        </div>
    </div>
</div>
