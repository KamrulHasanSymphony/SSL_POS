@model ShampanPOS.Models.SaleReturnVM
@{
    ViewBag.Title = "Sale Return Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 900px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            font-weight: bold;
        }

    .text-right {
        text-align: right;
    }

    /* 🔥 PRINT LIKE SALES REPORT */
    @@media print {

        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            margin: 0;
            padding: 20px;
            background: #fff;
            border: none;
        }

        .sslPrint {
            display: none !important;
        }
    }

    .purchasetotalrow td {
        border: 0 !important
    }

        .purchasetotalrow td span {
            border-bottom: 1px solid #000 !important;
            position: relative
        }

            .purchasetotalrow td span::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -3px;
                width: 100%;
                height: 1px;
                background: #000;
            }
</style>


<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png"
                     style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;">@Model.CompanyName </h3>
                <div style="font-size:16px;">@Model.BranchName</div>
                <div>@Model.BranchAddress 69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>

        </tr>
    </table>

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        SALES RETURN
    </h2>

    <!-- MASTER INFO -->
    @*<h3>Sales Return Information</h3>*@
    <table>
        <tr>
            <th>Return Code</th>
            <td>@Model.Code</td>
            <th>Return Date</th>
            <td style="width: 25%!important">@Model.InvoiceDateTime</td>
        </tr>
        <tr>
            <th>Customer</th>
            <td>@Model.CustomerName</td>
            <th>Delivery Address</th>
            <td style="width: 25%!important">@Model.DeliveryAddress</td>
        </tr>
    </table>

    <!-- DETAILS -->
    <h3>Return Items</h3>
    <table>
        <thead>
            <tr>
                <th style="width:5%!important;" class="text-center">SL</th>
                <th class="text-center">Product</th>
                <th class="text-center">Code</th>
                <th style="width:8%!important;" class="text-center">Qty</th>
                <th style="width:10%!important;" class="text-center">Unit Rate</th>
                <th style="width:10%!important;" class="text-center">SD Amt</th>
                <th style="width:10%!important;" class="text-center">VAT Amt</th>
                <th style="width:10%!important;" class="text-center">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.saleReturnDetailList)
            {
                <tr>
                    <td>@item.Line</td>
                    <td>@item.ProductName</td>
                    <td>@item.ProductCode</td>
                    <td class="text-right">@item.Quantity</td>
                    <td class="text-right">@item.UnitRate</td>
                    <td class="text-right">@item.SDAmount</td>
                    <td class="text-right">@item.VATAmount</td>
                    <td class="text-right">@item.LineTotal</td>
                </tr>
            }

            <!-- 🔥 TOTAL ROW -->
        <tr class="purchasetotalrow" style="font-weight:bold;">
            <td colspan="3" style="text-align:center;">Total :</td>

            <td class="text-right">
                <span>@(Model.saleReturnDetailList?.Sum(x => x.Quantity) ?? 0)</span>
            </td>

            <td></td>

            <td class="text-right">
                <span>@(Model.saleReturnDetailList?.Sum(x => x.SDAmount) ?? 0)</span>
            </td>

            <td class="text-right">
                <span>@(Model.saleReturnDetailList?.Sum(x => x.VATAmount) ?? 0)</span>
            </td>

            <td class="text-right">
                <span>@(Model.saleReturnDetailList?.Sum(x => x.LineTotal) ?? 0)</span>
            </td>
        </tr>

        </tbody>
    </table>

    <!-- COMMENTS-->
    <div style="margin-top:20px;">
        <h5 class="section-title">Comments</h5>
        <div style="margin-top:5px;">
            @Model.Comments
        </div>
    </div>
</div>

