@model List<ShampanPOS.Models.SaleReportVM>
@{
    ViewBag.Title = "Sale vs Sale Return Summary";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool hasProduct = (ViewBag.ProductId != null && (int)ViewBag.ProductId > 0);
    bool hasCustomer = (ViewBag.CustomerId != null && (int)ViewBag.CustomerId > 0);
    bool singleCombo = hasProduct && hasCustomer;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
    }

    .info-block {
        background: #f8f9fa;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 15px;
        margin-bottom: 15px;
    }

        .info-block h4 {
            margin: 0 0 10px 0;
        }

    .single-summary-card {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

        .single-summary-card .box {
            flex: 1;
            min-width: 150px;
            background: white;
            border: 1px solid #ccc;
            border-radius: 6px;
            padding: 12px;
            text-align: center;
        }

            .single-summary-card .box .label {
                font-size: 12px;
                color: #666;
            }

            .single-summary-card .box .value {
                font-size: 18px;
                font-weight: bold;
                margin-top: 4px;
            }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">Print</button>

<div class="report-box">

    <!-- HEADER -->
    <table style="border:none;margin-bottom:10px;">
        <tr>
            <td style="width:140px;border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png" style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right;border:none;">
                <h3 style="margin:0;"> @ViewBag.CompanyName </h3>
                <div> @ViewBag.BranchName </div>
                <div>69/1 Trhidara Tower</div>
                <div>📞 01612264439</div>
                <div>✉️ symphonysorftech1999@gamil.com</div>
            </td>
        </tr>
    </table>

    <h2 style="text-align:center;border-bottom:1px solid #000;">
        SALE VS SALE RETURN REPORT (SUMMARY)
    </h2>

    @using System.Globalization
    @{
        var bd = new CultureInfo("en-IN");
        var first = Model != null && Model.Any() ? Model.First() : null;
    }

    @* ===================== CASE A: Product + Customer both selected ===================== *@
    @if (singleCombo)
    {
        <div class="info-block">
            <h4>
                Customer: @(first != null ? $"{first.CustomerName} ({first.CustomerCode})" : "N/A")
                &nbsp;|&nbsp;
                Product: @(first != null ? $"{first.ProductName} ({first.ProductCode})" : "N/A")
            </h4>
        </div>

        <div class="single-summary-card">
            <div class="box">
                <div class="label">Sale Qty</div>
                <div class="value">@((first?.SaleQty ?? 0))</div>
            </div>
            <div class="box">
                <div class="label">Sale Amount</div>
                <div class="value">@((first?.SaleAmount ?? 0).ToString("N2", bd))</div>
            </div>
            <div class="box">
                <div class="label">Return Qty</div>
                <div class="value">@((first?.SaleReturnQty ?? 0))</div>
            </div>
            <div class="box">
                <div class="label">Return Amount</div>
                <div class="value">@((first?.SaleReturnAmount ?? 0).ToString("N2", bd))</div>
            </div>
        </div>
    }
    else
    {
        @* ===================== CASE B/C/D: breakdown table ===================== *@

        if (hasProduct)
        {
            <div class="info-block">
                <h4>Product: @(first != null ? $"{first.ProductName} ({first.ProductCode})" : ViewBag.ProductName)</h4>
            </div>
        }
        else if (hasCustomer)
        {
            <div class="info-block">
                <h4>Customer: @(first != null ? $"{first.CustomerName} ({first.CustomerCode})" : ViewBag.CustomerName)</h4>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>@(hasProduct ? "Customer" : "Product")</th>
                        <th>Sale Qty</th>
                        <th>Sale Amount</th>
                        <th>Return Qty</th>
                        <th>Return Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (hasProduct)
                                    {
                                        @($"{item.CustomerName} ({item.CustomerCode})")
                                    }
                                    else
                                    {
                                        @($"{item.ProductName} ({item.ProductCode})")
                                    }
                                </td>
                                <td class="text-right">@item.SaleQty</td>
                                <td class="text-right">@((item.SaleAmount ?? 0).ToString("N2", bd))</td>
                                <td class="text-right">@item.SaleReturnQty</td>
                                <td class="text-right">@((item.SaleReturnAmount ?? 0).ToString("N2", bd))</td>
                            </tr>
                        }

                        <tr style="font-weight:bold;background:#f1f1f1;">
                            <td>Total</td>
                            <td class="text-right">@Model.Sum(x => x.SaleQty)</td>
                            <td class="text-right">@((Model.Sum(x => x.SaleAmount) ?? 0).ToString("N2", bd))</td>
                            <td class="text-right">@Model.Sum(x => x.SaleReturnQty)</td>
                            <td class="text-right">@((Model.Sum(x => x.SaleReturnAmount) ?? 0).ToString("N2", bd))</td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align:center;padding:20px;">No data found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>