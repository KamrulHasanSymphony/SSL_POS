                    success: function (data) {
                        if (!data || data.length === 0) {
                            console.warn("No data found");
                            return;
                        }

                        let labels = data.map(x => x.MonthYear);  // Get Month and Year labels
                        let values = data.map(x => Number(x.TotalPurchaseValue));  // Get total purchase values for each month

                        const ctx = document.getElementById('totalPurchasesChart');
                        if (!ctx) return;

                        const chartCtx = ctx.getContext('2d');

                        // Check if a chart instance already exists and destroy it before re-creating
                        if (window.totalPurchasesChart instanceof Chart) {
                            window.totalPurchasesChart.destroy();
                        }

                        window.totalPurchasesChart = new Chart(chartCtx, {
                            type: 'line',  // Line chart
                            data: {
                                labels: labels,
                                datasets: [{
                                    label: 'Total Purchases (Last 3 Months)',
