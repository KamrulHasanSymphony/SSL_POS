@model ShampanPOS.Models.RegistrationVM
@{
    ViewBag.Title = "Registration Create";
    Layout = "~/Views/Shared/_SignUpLayout.cshtml";
}
@{
    var operation = @Model.Operation == "add" ? "Create" : "Update";
    var mode = @Model.Mode == "passwordchange" ? "Password" : "Profile";
}

<style>
    .sslSave,
    .sslUpdate {
        min-width: 110px;
        height: 40px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 4px;
    }

        .sslSave i,
        .sslUpdate i {
            margin-right: 5px;
        }
    .address-textarea {
        min-height: 60px !important;
        resize: vertical;
    }

</style>

<div class="container-fluid">
    <div class="row justify-content-center">

        <div class="col-lg-10 col-xl-8">

            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Registration Info</h5>
                </div>

                <div class="card-body">

                    <form id="frmEntry">

                        @Html.HiddenFor(model => model.Id)
                        @Html.HiddenFor(model => model.Operation)
                        @Html.HiddenFor(model => model.Mode)
                        @Html.HiddenFor(model => model.IsRegistration)

                        <div class="card shadow-sm">
                            <div class="card-body">

                                <div class="form-row">

                                    <div class="col-md-3 mb-3 codeWidth">
                                        @Html.LabelFor(model => model.Code)
                                        <div style="display:flex;align-items:center;">
                                            <span id="btnPrevious" class="fa fa-backward" style="color:darkseagreen;"></span>&nbsp;
                                            @Html.TextBoxFor(model => model.Code,
                                                new
                                                     {
                                                    placeholder = "Code Auto Generate",
                                                    @class = "csCode form-control form-control-sm",
                                                    @readonly = "readonly"
                                                })
                                            &nbsp;
                                            <span id="btnNext" class="fa fa-forward" style="color:darkseagreen;"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.EmailAsLoginId)
                                        @Html.TextBoxFor(model => model.EmailAsLoginId,
                                            new { @class = "form-control form-control-sm" })
                                        @Html.ValidationMessageFor(model => model.EmailAsLoginId)
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.Password)
                                        @Html.PasswordFor(model => model.Password,
                                            new
                                                 {
                                                @class = "form-control form-control-sm",
                                                autocomplete = "off"
                                            })
                                        @Html.ValidationMessageFor(model => model.Password)
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.ConfirmPassword)
                                        @Html.PasswordFor(model => model.ConfirmPassword,
                                            new
                                                 {
                                                @class = "form-control form-control-sm",
                                                autocomplete = "off"
                                            })
                                        @Html.ValidationMessageFor(model => model.ConfirmPassword)
                                    </div>

                                </div>

                                <div class="form-row">

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.FullName)
                                        @Html.TextBoxFor(model => model.FullName,
                                            new { @class = "form-control form-control-sm" })
                                        @Html.ValidationMessageFor(model => model.FullName)
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.PhoneNumber)
                                        @Html.TextBoxFor(model => model.PhoneNumber,
                                            new { @class = "form-control form-control-sm" })
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.CompanyName)
                                        @Html.TextBoxFor(model => model.CompanyName,
                                            new { @class = "form-control form-control-sm" })
                                        @Html.ValidationMessageFor(model => model.CompanyName)
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        @Html.LabelFor(model => model.CompanyAddress)
                                        @Html.TextAreaFor(model => model.CompanyAddress,
                                            new
                                                 {
                                                @class = "form-control form-control-sm",
                                                rows = "2"
                                            })
                                        @Html.ValidationMessageFor(model => model.CompanyAddress)
                                    </div>

                                </div>


                            </div>
                        </div>

                        <hr />

                        <div class="text-left mt-3">

                            <button type="button"
                                    class="btn btn-success btn-sm btnsave sslSave px-4">
                                <i class="fa fa-save mr-1"></i> Save
                            </button>

                            @*<button type="button"
                                    class="btn btn-success btn-sm sslUpdate px-4"
                                    style="display:none;">
                                <i class="fa fa-edit mr-1"></i> Update
                            </button>*@

                        </div>

                    </form>

                </div>
            </div>

        </div>

    </div>
</div>

@section scripts{

    <script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>
    <script src="~/Areas/SetUp/js/Controller/RegistrationController.js"></script>
    <script src="~/Areas/Common/js/Services/CommonValidationHelper.js"></script>
    <script>
        $(document).ready(function () {
            //$("#IsHeadOffice").bootstrapSwitch();
            //$("#IsSalePerson").bootstrapSwitch();

            RegistrationController.init();
        });


    </script>


}

