            function loadTopProductSales() {
                debugger;
                var combo = $("#Options").data("kendoComboBox");
                var top = combo ? combo.value() : 10;

                $.ajax({
                    url: '/Home/GetTopProductsLast3MonthsTotalSale',  // Ensure this is the correct API URL
                    type: 'GET',
                    data: { value: top },
                    success: function (data) {
                        if (!data || data.length === 0) {
                            console.warn("No data found");
                            return;
                        }

                        let labels = data.map(x => x.MonthYear);  // Get Month and Year labels
                        let values = data.map(x => Number(x.TotalSaleValue));  // Get total sale values for each month

                        const ctx = document.getElementById('topProductChart');
                        if (!ctx) return;

                        const chartCtx = ctx.getContext('2d');

                        if (window.topProductChart instanceof Chart) {
                            window.topProductChart.destroy();
                        }

                        window.topProductChart = new Chart(chartCtx, {
                            type: 'line',  // Change to line chart
                            data: {
                                labels: labels,
                                datasets: [{
                                    label: 'Total Sales (Last 3 Months)',
                                    data: values,
                                    borderColor: '#007bff',  // Line color
                                    backgroundColor: 'rgba(0, 123, 255, 0.2)',  // Line background color
                                    fill: true,  // Fill the area under the line
                                    tension: 0.1  // Smoothness of the line
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: { display: true },
                                    title: {
                                        display: true,
                                        text: 'Total Sales for the Last 3 Months',
                                        font: { size: 16, weight: 'bold' },
                                        padding: { top: 10, bottom: 20 }
                                    }
                                },
                                scales: {
                                    y: { beginAtZero: true }
                                }
                            }
                        });
                    },
                    error: function (err) {
                        console.error("Error:", err);
                    }
                });
            }

            function loadTotalPurchasesLast3Months(companyId) {
