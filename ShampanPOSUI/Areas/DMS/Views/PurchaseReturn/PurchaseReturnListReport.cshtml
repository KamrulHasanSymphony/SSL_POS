@model List<ShampanPOS.Models.PurchaseReturnReportVM>

@{
    ViewBag.Title = "Purchase Return Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isSummary = ViewBag.IsSummary != null && (bool)ViewBag.IsSummary;
}

<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1100px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #17a2b8;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        table th, table td {
            border: 1px solid #777;
            padding: 6px;
        }

        table th {
            background: #e9e9e9;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }
</style>

<button onclick="window.print()" class="sslPrint" style="float:right;margin:20px;">
    Print
</button>

<div class="report-box">

    <!-- TITLE -->
    <h2 style="text-align:center;border-bottom:1px solid #000;">
        PURCHASE RETURN REPORT (@(isSummary ? "SUMMARY" : "DETAILS"))
    </h2>

    <!-- TABLE -->
    <table>
        <thead>
            <tr>
                <th>Return Code</th>
                <th>Supplier</th>
                <th>Invoice Date Time</th>
                <th>Purchase Date</th>

                @if (!isSummary)
                {
                    <th>Product</th>
                    <th>Unit Price</th>
                    <th>SD</th>
                    <th>VAT Rate</th>
                }
                else
                {
                    <th>Product</th>
                }

                <th>Quantity</th>
                <th>Sub Total</th>
                <th>VAT Amount</th>
                <th>Line Total</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.SupplierName</td>
                        <td>@item.InvoiceDateTime</td>
                        <td>@item.PurchaseDate</td>

                        @if (!isSummary)
                        {
                            <td>@item.ProductName</td>
                            <td class="text-right">@item.UnitPrice</td>
                            <td class="text-right">@item.SD</td>
                            <td class="text-right">@item.VATRate</td>
                        }
                        else
                        {
                            <td>@item.ProductName</td>
                        }

                        <td class="text-right">@item.Quantity</td>
                        <td class="text-right">@item.SubTotal</td>
                        <td class="text-right">@item.VATAmount</td>
                        <td class="text-right">@item.LineTotal</td>
                    </tr>
                }

                <!-- ✅ TOTAL FIX -->
                <tr style="font-weight:bold;background:#f1f1f1;">
                    <td colspan="@(isSummary ? 5 : 8)">Total</td>

                    <td class="text-right">@Model.Sum(x => x.Quantity)</td>
                    <td class="text-right">@Model.Sum(x => x.SubTotal)</td>
                    <td class="text-right">@Model.Sum(x => x.VATAmount)</td>
                    <td class="text-right">@Model.Sum(x => x.LineTotal)</td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="12" style="text-align:center;">
                        No purchase return data found
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- FOOTER -->
    <div style="text-align:right;margin-top:10px;">
        <strong>Total Row:</strong> @(Model != null ? Model.Count : 0)
    </div>

</div>