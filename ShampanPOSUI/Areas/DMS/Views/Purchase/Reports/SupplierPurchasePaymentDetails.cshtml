@model List<ShampanPOS.Models.SupplierPurchasePaymentReportVM>
@{
    ViewBag.Title = "Supplier Purchase & Payment Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bd = new System.Globalization.CultureInfo("en-IN");

    var totalPurchase = Model.Where(x => x.TransactionType == "Purchase").Sum(x => x.PurchaseAmount);
    var totalPayment = Model.Where(x => x.TransactionType == "Payment").Sum(x => x.PaymentAmount);
    var outstanding = totalPurchase - totalPayment;
}
<style>
    body {
        font-family: Arial;
        background: #f2f2f2;
    }

    .report-box {
        background: white;
        padding: 20px;
        border: 1px solid #ccc;
        max-width: 1300px;
        margin: 20px auto;
        border-radius: 6px;
    }

    .sslPrint {
        background: #555;
        color: white;
        padding: 8px 20px;
        border-radius: 4px;
        border: none;
        float: right;
        margin-bottom: 10px;
        cursor: pointer;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-bottom: 18px;
    }

        table th, table td {
            border: 1px solid #555;
            padding: 6px;
        }

        table th {
            background: #d0d0d0;
            text-align: center;
        }

    .text-right {
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    .row-purchase {
        background: #f5f5f5;
    }

    .row-payment {
        background: #e0e0e0;
    }

    .group-header td {
        background: #333;
        color: #fff;
        font-weight: bold;
    }

    .subtotal-row td {
        background: #c8c8c8;
        font-weight: bold;
    }

    .total-purchase {
        background: #d8d8d8;
        font-weight: bold;
    }

    .total-payment {
        background: #c0c0c0;
        font-weight: bold;
    }

    .total-grand {
        background: #333;
        color: #fff;
        font-weight: bold;
    }

    .badge-purchase {
        background: #17a2b8;
        color: #fff;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
    }

    .badge-payment {
        background: #28a745;
        color: #fff;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
    }

    .report-footer {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-top: 10px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        .report-box, .report-box * {
            visibility: visible;
        }

        .sslPrint {
            display: none !important;
        }

        .report-box {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            max-width: 100%;
            margin: 0;
            padding: 10px;
            border: none;
        }

        @@page {
            size: A4 landscape;
            margin: 15mm 10mm;
        }

        thead {
            display: table-header-group;
        }

        tr {
            page-break-inside: avoid;
        }

        table th, table td {
            font-size: 10px;
            padding: 3px 4px;
        }
    }
</style>

<button onclick="window.print()" class="sslPrint">🖨️ Print</button>

<div class="report-box">
    <table style="border:none; margin-bottom:10px;">
        <tr>
            <td style="width:140px; border:none;">
                <img src="~/Content/AdminLte/dist/img/logo.png" style="width:230px;height:120px;" />
            </td>
            <td style="text-align:right; border:none;">
                <h3 style="margin:0;">@ViewBag.CompanyName</h3>
                <div>@ViewBag.BranchName</div>
                <div>📞 01612264439</div>
            </td>
        </tr>
    </table>
    <hr />

    <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:11px;">
        <div>
            <strong>Supplier:</strong> @ViewBag.SupplierName <br />
            <strong>From Date:</strong> @ViewBag.FromDate
        </div>
        <div style="text-align:right;">
            <strong>To Date:</strong> @ViewBag.ToDate <br />
        </div>
    </div>

    <h3 style="text-align:center; border-bottom:1px solid #000; padding-bottom:6px;">
        SUPPLIER PURCHASE &amp; PAYMENT REPORT (DETAILS)
    </h3>

    <div style="margin-bottom:8px; font-size:12px;">
        <span style="display:inline-block;width:14px;height:14px;background:#f5f5f5;
                     border:1px solid #555;margin-right:4px;vertical-align:middle;"></span> Purchase &nbsp;&nbsp;
        <span style="display:inline-block;width:14px;height:14px;background:#e0e0e0;
                     border:1px solid #555;margin-right:4px;vertical-align:middle;"></span> Payment
    </div>

    <div style="overflow-x:auto;">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Type</th>
                    <th>Code</th>
                    <th>Date</th>
                    <th>Purchase Amount</th>
                    <th>Payment Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int sl = 1;
                    decimal grandPurchase = 0, grandPayment = 0;

                    var supplierGroups = Model
                        .GroupBy(x => new { x.SupplierIdResult, x.SupplierCode, x.SupplierNameResult })
                        .OrderBy(g => g.Key.SupplierNameResult);

                    bool isMultipleSuppliers = supplierGroups.Count() > 1;

                    foreach (var grp in supplierGroups)
                    {
                        decimal subPurchase = grp.Where(x => x.TransactionType == "Purchase").Sum(x => (decimal)x.PurchaseAmount);
                        decimal subPayment = grp.Where(x => x.TransactionType == "Payment").Sum(x => (decimal)x.PaymentAmount);
                        grandPurchase += subPurchase;
                        grandPayment += subPayment;
                        decimal subDue = subPurchase - subPayment;

                        var sortedItems = grp
                            .OrderBy(x => x.TransactionType == "Purchase" ? 0 : 1)
                            .ThenBy(x => x.TransactionType == "Purchase" ? x.PurchaseDate : x.PaymentDate)
                            .ToList();

                        if (isMultipleSuppliers)
                        {
                            <tr class="group-header">
                                <td colspan="6">
                                    🏭 Supplier: @grp.Key.SupplierCode — @grp.Key.SupplierNameResult
                                </td>
                            </tr>
                        }

                        foreach (var item in sortedItems)
                        {
                            <tr class="@(item.TransactionType == "Purchase" ? "row-purchase" : "row-payment")">
                                <td class="text-center">@sl</td>
                                <td class="text-center">
                                    @if (item.TransactionType == "Purchase")
                                    {
                                        <span class="badge-purchase">Purchase</span>
                                    }
                                    else
                                    {
                                        <span class="badge-payment">Payment</span>
                                    }
                                </td>
                                <td>@(item.TransactionType == "Purchase" ? item.PurchaseCode : item.PaymentCode)</td>
                                <td class="text-center">@(item.TransactionType == "Purchase" ? item.PurchaseDate : item.PaymentDate)</td>
                                <td class="text-right">@(item.PurchaseAmount > 0 ? ((decimal)item.PurchaseAmount).ToString("N2", bd) : "-")</td>
                                <td class="text-right">@(item.PaymentAmount > 0 ? ((decimal)item.PaymentAmount).ToString("N2", bd) : "-")</td>
                            </tr>
                            sl++;
                        }

                        <tr class="subtotal-row">
                            <td colspan="2" class="text-right">Purchase Total:</td>
                            <td class="text-right">@subPurchase.ToString("N2")</td>
                            <td class="text-right">Pay Total:</td>
                            <td class="text-right">@subPayment.ToString("N2")</td>
                            <td class="text-right">Due: @subDue.ToString("N2")</td>
                        </tr>
                    }

                    if (isMultipleSuppliers)
                    {
                        <tr class="total-purchase">
                            <td colspan="4" class="text-right">Total Purchase:</td>
                            <td class="text-right">@grandPurchase.ToString("N2")</td>
                            <td></td>
                        </tr>
                        <tr class="total-payment">
                            <td colspan="5" class="text-right">Total Payment:</td>
                            <td class="text-right">@grandPayment.ToString("N2")</td>
                        </tr>
                        <tr class="total-grand">
                            <td colspan="5" class="text-right">Total Outstanding:</td>
                            <td class="text-right">@((grandPurchase - grandPayment).ToString("N2"))</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center">No data found</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="report-footer" style="border-top:1px solid #ccc; padding-top:5px;">
        <div>
            <strong>Printed By:</strong> @(ViewBag.PrintedBy ?? "N/A") |
            <strong>Printed On:</strong> @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </div>
    </div>
</div>
