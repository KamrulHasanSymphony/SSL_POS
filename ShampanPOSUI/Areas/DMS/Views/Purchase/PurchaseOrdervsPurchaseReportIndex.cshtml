                });

                wnd = $("#purchaseOrderWindow").data("kendoWindow");
            }

            wnd.center().open();

            LoadPurchaseOrderSupplierCombo();

            $("#purchaseOrderGrid").kendoGrid({
                dataSource: {
                    transport: {
                        read: {
                            url: "/Common/Common/GetPurchaseOrderModal",
