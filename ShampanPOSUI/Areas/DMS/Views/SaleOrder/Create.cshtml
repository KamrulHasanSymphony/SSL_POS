@using Newtonsoft.Json
@model ShampanPOS.Models.SaleOrderVM
@{
    ViewBag.Title = "Sale Order Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    var serial = 1;
}
<style>
    .k-dropdown-wrap .k-input {
        line-height: 1.6em !important;
    }

    .button.secondary {
        background-color: #adb5bd;
        color: #212529;
        border: 1px solid #adb5bd;
    }

    button[onclick*="reportLink"] {
        background: #138496;
        color: white;
        padding: 8px 16px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s ease-in-out;
    }

        button[onclick*="reportLink"]:hover {
            background: #117a8b;
        }

        button[onclick*="reportLink"]:focus {
            outline: none;
        }
</style>


<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"> Sale Order Entry </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li id="btnBack"><img src="~/Content/css/ButtonsIcons/back-icon.png" title="Click for Go Back" /></li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="card">
    <div class="card-header p-2">


        @if (Model.IsPost)
        {
            <!-- LEFT SIDE -->
            <div style="display:flex; align-items:center; gap:5px;">

                <button type="button" class="button sslPush">Already Posted</button>

                <button type="button" onclick="document.getElementById('reportLink').click();">
                    <i class="k-icon k-i-print"></i> Print
                </button>

                <a id="reportLink"
                   href="/DMS/SaleOrder/getReport/@Model.Id"
                   style="display:none;">
                </a>

                <button type="button" class="button secondary" id="btnFromPurchaseOrder">
                    <span style="font-weight:bold; margin-right:5px;">+</span> Sale
                </button>

                <!-- ✅ Right side -->
                <button type="button"
                        style="margin-left:auto;"
                        title="Add New"
                        data-url="/DMS/SaleOrder/Create"
                        onclick="GoTo(this)"
                        class="button NewButton addNewButton">
                    New
                </button>

            </div>
        }

        else if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
        {
            <div style="display:flex; align-items:center; justify-content:space-between;">

                <!-- LEFT SIDE -->
                <div style="display:flex; align-items:center; gap:5px;">

                    <button type="button" class="button btnsave sslUpdate">Update</button>

                    <button type="button" class="button btnPost sslPost">Post</button>

                    <button type="button" style="display:none;" class="button sslPush">Already Posted</button>

                    <button type="button" onclick="document.getElementById('reportLink').click();">
                        <i class="k-icon k-i-print"></i> Print
                    </button>

                </div>

                <!-- RIGHT SIDE -->
                <button type="button"
                        title="Add New"
                        data-url="/DMS/SaleOrder/Create"
                        onclick="GoTo(this)"
                        class="button NewButton addNewButton">
                    New
                </button>

            </div>

            <a id="reportLink"
               href="/DMS/SaleOrder/getReport/@Model.Id"
               style="display:none;">
            </a>

        }
        else
        {

            <div style="display:none;" class="divUpdate">

                <div style="display:flex; align-items:center; justify-content:space-between; width:100%;">

                    <div style="display:flex; align-items:center; gap:5px;">


                        <button type="button" class="button btnsave sslUpdate">Update</button>

                        <button type="button" class="button btnPost sslPost">Post</button>
                        <button type="button" style="display:none;" class="button sslPush">Already Posted</button>

                        <button type="button" onclick="document.getElementById('reportLink').click();">
                            <i class="k-icon k-i-print"></i> Print
                        </button>

                        @*<button style="float:right;" type="button" title="Add New" data-url="/DMS/SaleOrder/Create" onclick="GoTo(this)" class="button NewButton addNewButton">
                New
            </button>*@

                    </div>

                    <!-- RIGHT SIDE -->
                    <button type="button"
                            title="Add New"
                            data-url="/DMS/SaleOrder/Create"
                            onclick="GoTo(this)"
                            class="button NewButton addNewButton">
                        New
                    </button>
                </div>

            <a id="reportLink"
               href="/DMS/SaleOrder/getReport/@Model.Id"
               style="display:none;">
            </a>
        </div>
            <div class="divSave">
                <button class="button btnsave sslSave" type="button" id="">Save</button>
            </div>
        }

    </div>
</div>
<div class="container-fluid">
    <form id="frmEntry">
        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title"> Sale Order Info </h3>
            </div>
            <div class="card-body">

                @Html.HiddenFor(model => model.Id)

                @Html.HiddenFor(model => model.DecimalPlace)
                @Html.HiddenFor(model => model.Operation)
                @Html.HiddenFor(model => model.IsPost)
                @Html.HiddenFor(model => model.BranchId)
                @Html.HiddenFor(model => model.TransactionType)
                @*@Html.HiddenFor(model => model.FromDate)*@


                @Html.Hidden("SaleOrderDetailsJson", JsonConvert.SerializeObject(Model.saleOrderDetailsList ?? new List<ShampanPOS.Models.SaleOrderDetailVM>()))

                <div class="form-group row">

                    <div class="col-sm-2 codeWidth">
                        @Html.LabelFor(model => model.Code)
                        <div style="display: flex; align-items: center;">
                            <span id="btnPrevious" class="fa fa-backward" style="color: darkseagreen;"></span>&nbsp;
                            @Html.TextBoxFor(model => model.Code, new { placeholder = "Auto Generate Code", @class = " csCode  form-control form-control-sm", @readonly = "readonly", @style = "width:100% !important;" }) &nbsp;
                            <span id="btnNext" class="fa fa-forward" style="color: darkseagreen;"></span>
                        </div>
                    </div>

                    @*<div class="col-sm-2">
                            @Html.LabelFor(model => model.OrderDate)
                            <div class="input-group date">
                                @Html.TextBoxFor(model => model.OrderDate, new { @class = "  form-control form-control-sm dateRange" })
                                <div class="input-group-append">
                                    <div class="input-group-text"><i class="far fa-calendar-alt"></i></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-2">
                            @Html.LabelFor(model => model.DeliveryDate)
                            <div class="input-group date">
                                @Html.TextBoxFor(model => model.DeliveryDate, new { @class = "  form-control form-control-sm dateRange" })
                                <div class="input-group-append">
                                    <div class="input-group-text"><i class="far fa-calendar-alt"></i></div>
                                </div>
                            </div>
                        </div>*@



                    <div class="col-sm-2 pr-3">
                        @Html.LabelFor(model => model.OrderDate)

                        @Html.TextBoxFor(model => model.OrderDate, new
                   {
                       @class = "kendoOrderDate",
                       style = "width:100%; height:2em;"

                   })
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.DeliveryDate)

                        @Html.TextBoxFor(model => model.DeliveryDate, new
                   {
                       @class = "kendoDeliveryDate",
                       style = "width:100%; height:2em;"
                   })
                    </div>

                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.CustomerId)
                        <div class="input-group ">
                            @Html.TextBoxFor(model => model.CustomerId, new { @class = " required form-control form-control-sm ", @style = "width: 100%;" })
                        </div>
                        <span id="titleError2" class="text-danger" style="display:none;"></span>
                    </div>

                    <div class="col-sm-3">
                        @Html.LabelFor(model => model.DeliveryAddress)
                        <div class="input-group ">
                            @Html.TextAreaFor(model => model.DeliveryAddress, new { placeholder = "Enter delivery address", @class = "  form-control form-control-sm " })

                        </div>
                        @Html.ValidationMessageFor(model => model.DeliveryAddress)
                    </div>

                </div>

                <div class="form-group row">



                    <div class="col-sm-3">
                        @Html.LabelFor(model => model.Comments)
                        <div class="input-group ">
                            @Html.TextAreaFor(model => model.Comments, new { placeholder = "Enter Comments", @class = "  form-control form-control-sm " })

                        </div>
                        @Html.ValidationMessageFor(model => model.Comments)
                    </div>

                </div>

            </div>
        </div>

        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title"> Sale Order Details </h3>
            </div>
            <div class="card-body">
                <div id="saleOrderDetails"></div>
            </div>
        </div>


    </form>


    <div id="saleDetailsWindow" style="display:none;">
        <div id="saleDetailsGrid"></div>
    </div>


    <div class="card" style="flex-direction: row; justify-content: space-between; align-items: center;">
        <div class="card-header p-2">

            @if (Model.IsPost)
            {
                <div style="display:flex; align-items:center;">
                    <button type="button" class="button sslPush">Already Posted</button>

                    <button type="button" style="margin-left:5px;" onclick="document.getElementById('reportLink').click();">
                        <i class="k-icon k-i-print"></i> Print
                    </button>

                    <a id="reportLink"
                       href="/DMS/SaleOrder/getReport/@Model.Id"
                       style="display:none;">
                    </a>
                </div>
            }
            else if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
            {

        <div style="display: flex; align-items: center; gap: 5px;">
            <button style="float:left;" type="button" class="button btnsave sslUpdate">Update</button>
            <button type="button" class="button btnPost sslPost">Post</button>
            @*<button class="button sslPrintC " data-id="@Model.Id" style="float:right;">Print</button>*@

            <button type="button" style="display:none;" class="button sslPush">Already Posted</button>

            <button type="button" onclick="document.getElementById('reportLink').click();">
                <i class="k-icon k-i-print"></i> Print
            </button>

            <a id="reportLink"
               href="/DMS/SaleOrder/getReport/@Model.Id"
               style="display:none;">
            </a>

        </div>


            }
            else
            {

        <div style="display:none;" class="divUpdate">

            <div style="display:flex; align-items:center; gap:5px;">

                <button type="button" class="button btnsave sslUpdate">Update</button>

                <button type="button" class="button btnPost sslPost">Post</button>
                <button type="button" style="display:none;" class="button sslPush">Already Posted</button>
                <button type="button" onclick="document.getElementById('reportLink').click();">
                    <i class="k-icon k-i-print"></i> Print
                </button>

                <a id="reportLink"
                   href="/DMS/SaleOrder/getReport/@Model.Id"
                   style="display:none;">
                </a>

            </div>
        </div>
            <div class="divSave">
                <button class="button btnsave sslSave" type="button" id="">Save</button>
            </div>

            }

        </div>

        <div class="auditshow"> <img src="~/Content/Images/audit.png" title="Click for Audit" /> </div>
    </div>

    <div class="card card-secondary auditcard">

        <div class="card-header">
            <h3 class="card-title">Audit Details</h3>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-sm-2">
                    <div class="row">
                        @Html.Label("Type")
                    </div>
                </div>
                <div class="col-sm-10">
                    <div class="row">
                        <div class="col-sm-3">
                            @Html.Label("Created")
                        </div>
                        <div class="col-sm-3">
                            @Html.Label("Updated")
                        </div>
                        <div class="col-sm-3">
                            @Html.Label("Posted")
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-sm-2">
                    <div class="row">
                        <div class="col-sm-12">
                            @Html.Label("By")<br /><div class="clearfix">&nbsp;</div>
                            @Html.Label("On")<br /><div class="clearfix">&nbsp;</div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-10">
                    <div class="row">
                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.CreatedBy, new { @class = "CreatedBy  form-control form-control-sm ", @readonly = "readonly" })
                            <div class="clearfix">&nbsp;</div>
                            @Html.TextBoxFor(model => model.CreatedOn, new { @class = "CreatedOn  form-control form-control-sm ", @readonly = "readonly" })
                        </div>

                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.LastModifiedBy, new { @class = "LastUpdateBy  form-control form-control-sm lub", @readonly = "readonly" })
                            <div class="clearfix">&nbsp;</div>
                            @Html.TextBoxFor(model => model.LastModifiedOn, new { @class = "LastUpdateOn  form-control form-control-sm luo", @readonly = "readonly" })
                        </div>
                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.PostBy, new { @class = "PostedBy  form-control form-control-sm ", @readonly = "readonly" })<div class="clearfix">&nbsp;</div>
                            @Html.TextBoxFor(model => model.PosteOn, new { @class = "PostedOn  form-control form-control-sm ", @readonly = "readonly" })

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>



@section scripts{
    <script src="~/Areas/Common/js/Services/CommonService.js"></script>
    <script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>
    <script src="~/Areas/DMS/js/Controllers/SaleOrderController.js"></script>
    <script src="~/Areas/Common/js/Services/CommonValidationHelper.js"></script>
    <script>
        $(document).ready(function () {
            SaleOrderController.init();
        });

    </script>


}

